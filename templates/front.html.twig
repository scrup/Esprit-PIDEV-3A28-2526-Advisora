<script>
  function showToastMessage(msg) {
    alert(msg + ' ✨');
  }

  const btnsPrimary = document.querySelectorAll('.btn-primary');
  btnsPrimary.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      if(btn.id === 'newsSignupBtn') {
        const emailInput = document.getElementById('newsEmail');
        if(emailInput.value && emailInput.value.includes('@')) {
          showToastMessage(`📬 Merci ! ${emailInput.value} est maintenant abonné.`);
          emailInput.value = '';
        } else {
          showToastMessage('📧 Veuillez entrer une adresse email valide.');
        }
      } else if(btn.id === 'heroCta') {
        showToastMessage('🚀 Explorez notre démo interactive — planifiez une visite guidée dès aujourd\'hui.');
      } else if(btn.id === 'ctaBannerBtn') {
        showToastMessage('🎯 Demande de démo reçue ! Notre équipe vous contactera sous 24h.');
      } else if(btn.id === 'getStartedBtn') {
        showToastMessage('🎉 Bienvenue ! Créez votre compte de conseil gratuit.');
      } else {
        showToastMessage('Fonctionnalité à venir — version améliorée en route.');
      }
    });
  });

  const loginBtn = document.getElementById('loginBtn');
  if(loginBtn) {
    loginBtn.addEventListener('click', () => {
      showToastMessage('🔐 Accès sécurisé — connectez-vous avec SSO ou email.');
    });
  }

  const cardLinks = document.querySelectorAll('.card-link');
  cardLinks.forEach(link => {
    link.addEventListener('click', () => {
      showToastMessage('📈 Plongez plus profond : livres blancs et études de cas disponibles.');
    });
  });

  // TND Currency ticker simulation
  function updateTNDTicker() {
    let tndusd = parseFloat(document.getElementById('tndusd').innerText);
    let tndeur = parseFloat(document.getElementById('tndeur').innerText);
    let tndgbp = parseFloat(document.getElementById('tndgbp').innerText);
    let tndjpy = parseFloat(document.getElementById('tndjpy').innerText);
    let tndchf = parseFloat(document.getElementById('tndchf').innerText);
    let tndcad = parseFloat(document.getElementById('tndcad').innerText);
    let tndcny = parseFloat(document.getElementById('tndcny').innerText);

    const randomMove = () => (Math.random() - 0.5) * 0.0015;
    const randomMoveJpy = () => (Math.random() - 0.5) * 0.25;
    const randomMoveCny = () => (Math.random() - 0.5) * 0.008;

    let newTNDUSD = +(tndusd + randomMove()).toFixed(4);
    let newTNDEUR = +(tndeur + randomMove()).toFixed(4);
    let newTNDGBP = +(tndgbp + randomMove()).toFixed(4);
    let newTNDJPY = +(tndjpy + randomMoveJpy()).toFixed(2);
    let newTNDCHF = +(tndchf + randomMove()).toFixed(4);
    let newTNDCAD = +(tndcad + randomMove()).toFixed(4);
    let newTNDCNY = +(tndcny + randomMoveCny()).toFixed(4);

    let changeUSD = ((newTNDUSD - tndusd) / tndusd * 100).toFixed(2);
    let changeEUR = ((newTNDEUR - tndeur) / tndeur * 100).toFixed(2);
    let changeGBP = ((newTNDGBP - tndgbp) / tndgbp * 100).toFixed(2);
    let changeJPY = ((newTNDJPY - tndjpy) / tndjpy * 100).toFixed(2);
    let changeCHF = ((newTNDCHF - tndchf) / tndchf * 100).toFixed(2);
    let changeCAD = ((newTNDCAD - tndcad) / tndcad * 100).toFixed(2);
    let changeCNY = ((newTNDCNY - tndcny) / tndcny * 100).toFixed(2);

    function setChange(elementId, changeVal) {
      let span = document.getElementById(elementId);
      if(span) {
        let num = parseFloat(changeVal);
        let isPositive = num >= 0;
        span.innerText = (isPositive ? `▲ +${Math.abs(num)}%` : `▼ -${Math.abs(num)}%`);
        span.className = isPositive ? 'positive' : 'negative';
      }
    }

    document.getElementById('tndusd').innerText = newTNDUSD;
    document.getElementById('tndeur').innerText = newTNDEUR;
    document.getElementById('tndgbp').innerText = newTNDGBP;
    document.getElementById('tndjpy').innerText = newTNDJPY;
    document.getElementById('tndchf').innerText = newTNDCHF;
    document.getElementById('tndcad').innerText = newTNDCAD;
    document.getElementById('tndcny').innerText = newTNDCNY;

    setChange('tndusdChange', changeUSD);
    setChange('tndeurChange', changeEUR);
    setChange('tndgbpChange', changeGBP);
    setChange('tndjpyChange', changeJPY);
    setChange('tndchfChange', changeCHF);
    setChange('tndcadChange', changeCAD);
    setChange('tndcnyChange', changeCNY);
  }

  function randomizeTNDInitial() {
    let ids = ['tndusd', 'tndeur', 'tndgbp', 'tndjpy', 'tndchf', 'tndcad', 'tndcny'];
    ids.forEach(id => {
      let el = document.getElementById(id);
      if(el) {
        let base = parseFloat(el.innerText);
        let variance = base * (Math.random() - 0.5) * 0.003;
        let newVal = (base + variance).toFixed(id === 'tndjpy' ? 2 : 4);
        el.innerText = newVal;
      }
    });
    updateTNDTicker();
  }

  randomizeTNDInitial();
  let tickerInterval = setInterval(updateTNDTicker, 4500);
  window.addEventListener('beforeunload', () => {
    if(tickerInterval) clearInterval(tickerInterval);
  });

  document.querySelectorAll('nav a').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      e.preventDefault();
      showToastMessage(`📌 Navigation vers ${this.innerText} — explorez nos modules.`);
    });
  });
</script>
