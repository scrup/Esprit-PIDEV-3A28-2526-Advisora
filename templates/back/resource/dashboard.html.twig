{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Module Ressource{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
     <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
    <link rel="stylesheet" href="{{ asset('css/resource-backoffice.css') }}?v=20260417-rs-v29">
{% endblock %}

{% block body %}
    <section class="pm-admin-shell rs-admin-shell rs-module-resource" data-resource-chart-configs="{{ resource_charts|json_encode|e('html_attr') }}">
        <div class="pm-admin-header rs-header">
            <div class="rs-header-copy back-users-title">
                <span class="pm-badge">Back office</span>
                <h1>Gestion des ressources</h1>
                <p>Vue de synthese pour suivre rapidement l etat du stock et les ressources deja affectees aux projets.</p>
            </div>
        </div>

        {% include 'back/resource/_module_nav.html.twig' %}

        <section class="users-overview-grid rs-stat-grid">
            <article class="users-stat-card rs-stat-box">
                <span>Total ressources</span>
                <strong>{{ metrics.total_resources }}</strong>
            </article>
            <article class="users-stat-card rs-stat-box">
                <span>Disponibles</span>
                <strong>{{ metrics.available_resources }}</strong>
            </article>
            <article class="users-stat-card rs-stat-box">
                <span>Stock disponible</span>
                <strong>{{ metrics.stock_available }}</strong>
            </article>
            <article class="users-stat-card rs-stat-box">
                <span>Reservations</span>
                <strong>{{ metrics.total_reservations }}</strong>
            </article>
        </section>

        <section class="rs-charts-grid">
            <article class="pm-card rs-panel rs-chart-panel">
                <div class="pm-card-head rs-panel-head">
                    <div>
                        <h2>Stock global</h2>
                        <p>Part du stock reserve vs disponible</p>
                    </div>
                </div>
                <div class="rs-chart-wrap">
                    <canvas id="rs-stock-distribution-chart" aria-label="Repartition du stock global" role="img"></canvas>
                </div>
            </article>

            <article class="pm-card rs-panel rs-chart-panel">
                <div class="pm-card-head rs-panel-head">
                    <div>
                        <h2>Ressources par statut</h2>
                        <p>Disponibles, reservees et indisponibles</p>
                    </div>
                </div>
                <div class="rs-chart-wrap">
                    <canvas id="rs-status-distribution-chart" aria-label="Repartition des statuts de ressources" role="img"></canvas>
                </div>
            </article>

            <article class="pm-card rs-panel rs-chart-panel">
                <div class="pm-card-head rs-panel-head">
                    <div>
                        <h2>Top ressources affectees</h2>
                        <p>Nombre de projets lies (Top 8)</p>
                    </div>
                </div>
                <div class="rs-chart-wrap">
                    <canvas id="rs-project-links-chart" aria-label="Top des ressources affectees aux projets" role="img"></canvas>
                </div>
            </article>
        </section>

        <section class="pm-card rs-panel rs-list-panel">
            <div class="pm-card-head rs-panel-head">
                <div>
                    <h2>Ressources actuellement affectees</h2>
                    <p>Elements avec reservation(s) active(s). Cliquez sur le nom d une ressource pour ouvrir sa fiche.</p>
                </div>
            </div>

            {% if linked_resources is not empty %}
                <div class="back-user-table-shell rs-table-wrap">
                    <table class="back-user-table rs-table rs-list-table">
                        <thead>
                            <tr>
                                <th>Ressource</th>
                                <th>Fournisseur</th>
                                <th class="rs-col-number">Stock disponible</th>
                                <th class="rs-col-number">Reservations</th>
                                <th>Projets lies</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for resource in linked_resources %}
                                {% set stock = stock_snapshots[resource.id] ?? {'reserved': 0, 'available': resource.quantity ?? 0} %}
                                <tr class="back-user-row">
                                    <td>
                                        <div class="rs-resource-cell">
                                            <a class="rs-thumb" href="{{ path('resource_back_manage', {id: resource.id}) }}">
                                                {% if resource.primaryImageUrl %}
                                                    <img src="{{ resource.primaryImageUrl }}" alt="{{ resource.name }}">
                                                {% else %}
                                                    <i class="fas fa-box-open"></i>
                                                {% endif %}
                                            </a>
                                            <div class="rs-resource-copy">
                                                <a class="rs-primary-link" href="{{ path('resource_back_manage', {id: resource.id}) }}">{{ resource.name }}</a>
                                                <span class="rs-secondary-text">#{{ resource.id }} - Ouvrir la fiche</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>{{ resource.getSupplierDisplayName() }}</td>
                                    <td class="rs-cell-number">{{ stock.available }}</td>
                                    <td class="rs-cell-number">{{ resource.projects|length }}</td>
                                    <td>
                                        <div class="rs-project-tags">
                                            {% for project in resource.projects|slice(0, 3) %}
                                                <span class="rs-project-tag">{{ project.title }}</span>
                                            {% else %}
                                                <span class="rs-secondary-text">Aucun projet</span>
                                            {% endfor %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="pm-empty rs-empty">
                    <h2>Aucune liaison ressource/projet</h2>
                    <p>Les reservations client visibles dans <strong>project_resources</strong> apparaitront ici.</p>
                </div>
            {% endif %}
        </section>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
            if (typeof window.Chart === 'undefined') {
                return;
            }

            const dashboardNode = document.querySelector('.rs-module-resource[data-resource-chart-configs]');
            if (!dashboardNode) {
                return;
            }

            const rawChartConfigs = dashboardNode.getAttribute('data-resource-chart-configs');
            if (!rawChartConfigs) {
                return;
            }

            let chartConfigs = {};
            try {
                chartConfigs = JSON.parse(rawChartConfigs);
            } catch (error) {
                return;
            }

            const chartTargets = {
                stock_distribution: 'rs-stock-distribution-chart',
                status_distribution: 'rs-status-distribution-chart',
                project_links: 'rs-project-links-chart'
            };

            Object.entries(chartTargets).forEach(([chartKey, elementId]) => {
                const canvas = document.getElementById(elementId);
                const config = chartConfigs[chartKey] ?? null;

                if (!canvas || !config) {
                    return;
                }

                const context = canvas.getContext('2d');
                if (!context) {
                    return;
                }

                if (canvas.rsChartInstance) {
                    canvas.rsChartInstance.destroy();
                }

                canvas.rsChartInstance = new window.Chart(context, config);
            });
        })();
    </script>
{% endblock %}
