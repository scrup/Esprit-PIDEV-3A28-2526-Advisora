{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Module Ressource{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
     <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block body %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">Back office</span>
                <h1>Gestion des ressources</h1>
                <p>Consultez les liaisons Ressource/Projet du module avec un rendu visuel coherent avec Gestion Projet.</p>
            </div>
            <div class="pm-card-actions">
                <a class="pm-btn pm-btn-secondary" href="{{ path('app_back') }}">Retour au tableau de bord</a>
            </div>
        </div>

        {% include 'back/resource/_module_nav.html.twig' %}

        <section class="pm-grid">
            {% for resource in linked_resources %}
                <article class="pm-card">
                    <div class="pm-card-head">
                        <span class="pm-status pm-status-reserved">Liaison active</span>
                        <span class="pm-meta">Ressource #{{ resource.id }}</span>
                    </div>
                    <h2>{{ resource.name }}</h2>
                    <p>Suivi des liaisons Ressource/Projet en provenance de <strong>project_resources</strong>.</p>
                    <div class="pm-meta-list pm-meta-list-vertical">
                        <span><strong>Fournisseur :</strong> {{ resource.getSupplierDisplayName() }}</span>
                        <span><strong>Reservations liees :</strong> {{ resource.projects|length }}</span>
                    </div>
                    <div class="pm-project-chip-list">
                        {% for project in resource.projects|slice(0, 3) %}
                            <span class="pm-project-chip">{{ project.title }}</span>
                        {% else %}
                            <span class="pm-project-chip pm-project-chip-empty">Aucune reservation rattachee</span>
                        {% endfor %}
                    </div>
                    <div class="pm-card-actions">
                        <a class="pm-btn pm-btn-primary" href="{{ path('resource_back_manage', {id: resource.id}) }}">Traiter</a>
                    </div>
                </article>
            {% else %}
                <div class="pm-empty">
                    <h2>Aucune liaison ressource/projet</h2>
                    <p>Les reservations client visibles dans <strong>project_resources</strong> apparaitront ici.</p>
                </div>
            {% endfor %}
        </section>
    </section>
{% endblock %}
