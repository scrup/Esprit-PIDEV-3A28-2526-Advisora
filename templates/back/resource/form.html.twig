{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ page_badge|default('Gestion ressource') }}</span>
                <h1>{{ page_title }}</h1>
                <p>{{ page_message|default('Renseignez les informations de la ressource.') }}</p>
            </div>
            <div class="pm-card-actions">
                <a class="pm-btn pm-btn-secondary" href="{{ path('supplier_new') }}">Ajouter un fournisseur</a>
                <a class="pm-btn pm-btn-secondary" href="{{ resource.id ? path(back_route|default('resource_back_manage'), {id: resource.id}) : path('back_resource_index') }}">Retour</a>
            </div>
        </div>

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Statut actuel :</strong> {{ resource.statusLabel ?: 'Sera determine a l enregistrement.' }}
                <br>
                <strong>Reservations liees :</strong> {{ resource.id ? resource.projects|length : 0 }}
            </div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', class: 'pm-validated-form', 'data-validation-form': 'resource'}}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {{ forms.field(form.nomRs) }}
                    {{ forms.field(form.cataloguefournisseur) }}
                    {{ forms.field(form.prixRs) }}
                    {{ forms.field(form.QuantiteRs) }}
                    {{ forms.field(form.availabilityStatusRs) }}
                    {{ forms.field(form.imageUrlRs) }}
                </div>
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                    <a class="pm-btn pm-btn-secondary" href="{{ resource.id ? path(back_route|default('resource_back_manage'), {id: resource.id}) : path('back_resource_index') }}">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/project-form-validation.js') }}"></script>
{% endblock %}
