{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Historique des reservations{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
     <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block body %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">Gestion reservation</span>
                <h1>Historique global des reservations</h1>
                <p>Le gerant et l admin peuvent consulter, modifier ou supprimer toutes les reservations du module Ressource dans un ecran de suivi centralise.</p>
            </div>
            <div class="pm-card-actions">
                <a class="pm-btn pm-btn-secondary" href="{{ path('back_resource_dashboard') }}">Retour au dashboard</a>
                <a class="pm-btn pm-btn-secondary" href="{{ path('back_resource_index') }}">Retour aux ressources</a>
                <a class="pm-btn pm-btn-secondary" href="{{ path('resource_index') }}">Voir le front</a>
            </div>
        </div>

        {% include 'back/resource/_module_nav.html.twig' %}

        <section class="pm-grid">
            {% for reservation in reservations %}
                {% set supplierLabel = reservation.supplier_company ?: reservation.supplier_name ?: 'Non assigne' %}
                {% set clientLabel = (reservation.client_firstname ?: '') ~ ' ' ~ (reservation.client_lastname ?: '') %}
                {% set resourceStatusLabel = reservation.resource_status ? reservation.resource_status|replace({'_': ' '})|title : 'Statut inconnu' %}
                <article class="pm-card">
                    <div class="pm-card-head">
                        <span class="pm-status pm-status-{{ reservation.resource_status|default('')|lower|replace({' ':'_','-':'_'}) }}">
                            {{ resourceStatusLabel }}
                        </span>
                        <span class="pm-meta">Projet #{{ reservation.project_id }}</span>
                    </div>
                    <h2>{{ reservation.resource_name }}</h2>
                    <p>Projet : <strong>{{ reservation.project_title }}</strong></p>
                    <div class="pm-meta-list pm-meta-list-vertical">
                        <span><strong>Client :</strong> {{ clientLabel|trim is not empty ? clientLabel|trim : reservation.client_email }}</span>
                        <span><strong>Email :</strong> {{ reservation.client_email }}</span>
                        <span><strong>Fournisseur :</strong> {{ supplierLabel }}</span>
                        <span><strong>Quantite reservee :</strong> {{ reservation.reserved_qty }}</span>
                        <span><strong>Stock total :</strong> {{ reservation.resource_stock }}</span>
                        <span><strong>Prix :</strong> {{ reservation.resource_price is not null ? reservation.resource_price|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</span>
                    </div>
                    <div class="pm-card-actions">
                        <a class="pm-btn pm-btn-secondary" href="{{ path('resource_show', {id: reservation.resource_id}) }}">Voir la ressource</a>
                        <a class="pm-btn pm-btn-primary" href="{{ path('back_resource_reservation_edit', {projectId: reservation.project_id, resourceId: reservation.resource_id}) }}">Modifier reservation</a>
                        <form method="post" action="{{ path('back_resource_reservation_delete', {projectId: reservation.project_id, resourceId: reservation.resource_id}) }}" onsubmit="return confirm('Supprimer cette reservation ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_reservation_' ~ reservation.project_id ~ '_' ~ reservation.resource_id) }}">
                            <button class="pm-btn pm-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </div>
                </article>
            {% else %}
                <div class="pm-empty">
                    <h2>Aucune reservation enregistree</h2>
                    <p>Les reservations creees par les clients apparaitront ici.</p>
                </div>
            {% endfor %}
        </section>
    </section>
{% endblock %}
