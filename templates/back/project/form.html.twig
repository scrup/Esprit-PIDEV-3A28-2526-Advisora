{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ page_badge|default('Back office') }}</span>
                <h1>{{ page_title }}</h1>
                <p>{{ page_message|default('Le propriétaire du projet est associé automatiquement à l utilisateur connecté.') }}</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ project.id ? path(back_route|default('project_back_manage'), {id: project.id}) : path(back_route|default('project_index')) }}">Retour</a>
        </div>

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Date de création :</strong> {{ project.startDate ? project.startDate|date('d/m/Y') : 'Sera renseignée à l enregistrement.' }}
                <br>
                <strong>Dernière mise à jour :</strong> {{ project.endDate ? project.endDate|date('d/m/Y H:i') : 'Aucune pour le moment.' }}
            </div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', 'data-skip-validation': 'true'}}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {{ forms.field(form.title) }}
                    {{ forms.field(form.legacyType) }}
                    {{ forms.field(form.legacyBudget) }}
                    {% if form.status is defined %}
                        {{ forms.field(form.status) }}
                    {% endif %}
                    {{ forms.field(form.startDate) }}
                </div>
                {{ forms.field(form.description) }}
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
