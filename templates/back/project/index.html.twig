{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/back-dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% block body %}
    <div class="dashboard-container">
        <div class="dashboard-header">
            <div class="welcome-section">
                <h1>Aperçu des projets</h1>
                <p>Voici la situation actuelle des projets et des décisions du module de gestion.</p>
            </div>
            <div class="date-badge">
                <i class="fas fa-calendar-alt"></i>
                <span id="currentDate"></span>
            </div>
        </div>

        <!-- Quick Actions - Compact & Modern -->
        <div class="quick-actions-bar">
            <div class="quick-actions-title">
                <i class="fas fa-bolt"></i>
                <span>Actions rapides</span>
            </div>
            <div class="quick-actions-buttons">
                <a href="{{ path('back_project_index') }}" class="quick-action-btn primary">
                    <i class="fas fa-folder-open"></i>
                    <span>Gérer les projets</span>
                    <i class="fas fa-arrow-right"></i>
                </a>
                <a href="{{ path('project_index') }}" class="quick-action-btn secondary">
                    <i class="fas fa-eye"></i>
                    <span>Voir le front</span>
                    <i class="fas fa-external-link-alt"></i>
                </a>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-folder-open"></i></div>
                <div class="stat-info">
                    <h3>Total projets</h3>
                    <div class="stat-value">{{ total_projects }}</div>
                    <span class="stat-trend">Tous les projets du module</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                <div class="stat-info">
                    <h3>Projets en attente</h3>
                    <div class="stat-value">{{ pending_projects }}</div>
                    <span class="stat-trend">À traiter par le back office</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="stat-info">
                    <h3>Projets acceptés</h3>
                    <div class="stat-value">{{ accepted_projects }}</div>
                    <span class="stat-trend">Validés par décision récente</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-gavel"></i></div>
                <div class="stat-info">
                    <h3>Décisions</h3>
                    <div class="stat-value">{{ total_decisions }}</div>
                    <span class="stat-trend">{{ refused_projects }} projets refusés</span>
                </div>
            </div>
        </div>

        <!-- Two Columns -->
        <div class="two-columns">
            <!-- Left Column: Latest Projects -->
            <div class="card-panel">
                <div class="panel-header">
                    <h3><i class="fas fa-clock"></i> Derniers projets soumis</h3>
                    <a href="{{ path('back_project_index') }}" class="view-link">
                        Voir tous <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="dashboard-list">
                    {% for project in latest_projects %}
                        <a class="dashboard-list-item" href="{{ path('project_back_manage', {id: project.id}) }}">
                            <div class="list-item-content">
                                <div class="list-item-icon">
                                    <i class="fas fa-file-alt"></i>
                                </div>
                                <div class="list-item-info">
                                    <strong>{{ project.title }}</strong>
                                    <p>
                                        <i class="fas fa-user"></i> 
                                        {{ project.user ? project.user.getPrenomUser() ~ ' ' ~ project.user.getNomUser() : 'Non assigné' }}
                                    </p>
                                </div>
                            </div>
                            <div class="dashboard-list-meta">
                                <span class="pm-status pm-status-{{ project.status|lower }}">{{ project.getStatusLabel() }}</span>
                                <span class="list-item-date">
                                    <i class="fas fa-calendar"></i>
                                    {{ project.startDate ? project.startDate|date('d/m/Y') : '' }}
                                </span>
                            </div>
                        </a>
                    {% else %}
                        <div class="dashboard-empty">
                            <i class="fas fa-inbox"></i>
                            <p>Aucun projet disponible.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>

            <!-- Right Column: Latest Decisions -->
            <div class="card-panel">
                <div class="panel-header">
                    <h3><i class="fas fa-history"></i> Dernières décisions</h3>
                    <a href="{{ path('back_project_index') }}" class="view-link">
                        Accéder aux projets <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
                <div class="dashboard-list">
                    {% for decision in latest_decisions %}
                        <a class="dashboard-list-item" href="{{ path('project_back_manage', {id: decision.project.id}) }}">
                            <div class="list-item-content">
                                <div class="list-item-icon">
                                    <i class="fas fa-gavel"></i>
                                </div>
                                <div class="list-item-info">
                                    <strong>{{ decision.project.title }}</strong>
                                    <p>{{ decision.descriptionD ?: 'Sans justification détaillée.'|slice(0, 60) }}{{ decision.descriptionD|length > 60 ? '...' : '' }}</p>
                                </div>
                            </div>
                            <div class="dashboard-list-meta">
                                <span class="pm-status pm-status-{{ decision.project.status|lower }}">
                                    {{ decision.getDecisionTitleLabel() ?: 'Décision' }}
                                </span>
                                <span class="list-item-date">
                                    <i class="fas fa-calendar"></i>
                                    {{ decision.dateDecision ? decision.dateDecision|date('d/m/Y') : '' }}
                                </span>
                            </div>
                        </a>
                    {% else %}
                        <div class="dashboard-empty">
                            <i class="fas fa-inbox"></i>
                            <p>Aucune décision enregistrée.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/back-dashboard.js') }}"></script>
{% endblock %}