{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Gestion du projet{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
     <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/project-task-board.js') }}"></script>
{% endblock %}

{% block body %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">Gestion projet</span>
                <h1>{{ project.title }}</h1>
                <p>
                    {{ project.description ?: 'Aucune description disponible.' }}
                    {% if not can_edit_project and can_manage_project and is_project_accepted %}
                        Ce projet est accepte : le client ne peut plus le modifier.
                    {% endif %}
                </p>
            </div>
            <div class="pm-card-actions">
                <button class="pm-btn pm-btn-secondary" type="button" data-tts-play data-audio-url="{{ path('project_speech', {id: project.id, scenario: 'summary'}) }}">
                    <i class="fas fa-volume-up"></i>
                    <span>Lire</span>
                </button>
                <a class="pm-btn pm-btn-secondary" href="{{ path('back_project_index') }}">Retour a la liste</a>
                <a class="pm-btn pm-btn-secondary" href="{{ path('project_show', {id: project.id}) }}">Voir en front</a>
                {% if can_edit_project %}
                    <a class="pm-btn pm-btn-primary" href="{{ path('project_edit', {id: project.id}) }}">Modifier le projet</a>
                {% endif %}
            </div>
        </div>

        <div class="pm-admin-grid">
            <article class="pm-card">
                <h2>Informations du projet</h2>
                <div class="pm-meta-list pm-meta-list-vertical">
                    <span><strong>Statut :</strong> {{ project.getStatusLabel() }}</span>
                    <span><strong>Type :</strong> {{ project.legacyType ?: 'Non precise' }}</span>
                    <span><strong>Budget :</strong> {{ project.legacyBudget is not null ? project.legacyBudget|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</span>
                    <span><strong>Avancement taches :</strong> {{ task_board.progress|number_format(2, '.', ' ') }}%</span>
                    <span><strong>Date de creation :</strong> {{ project.startDate ? project.startDate|date('d/m/Y') : 'Non precisee' }}</span>
                    <span><strong>Derniere mise a jour :</strong> {{ project.endDate ? project.endDate|date('d/m/Y H:i') : 'Non disponible' }}</span>
                    <span><strong>Utilisateur :</strong> {{ project.user ? project.user.getPrenomUser() ~ ' ' ~ project.user.getNomUser() : 'Non assigne' }}</span>
                </div>
                {% if can_delete_project %}
                    <form method="post" action="{{ path('project_delete', {id: project.id}) }}" onsubmit="return confirm('Supprimer ce projet ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_project_' ~ project.id) }}">
                        <button class="pm-btn pm-btn-danger" type="submit">Supprimer le projet</button>
                    </form>
                {% endif %}
            </article>

            <article class="pm-card">
                {% if latest_decision %}
                    <div class="pm-current-decision">
                        <span class="pm-badge">Decision actuelle</span>
                        <strong>{{ latest_decision.getDecisionTitleLabel() }}</strong>
                        <span>{{ latest_decision.decisionDate|date('d/m/Y') }}</span>
                        <p>{{ latest_decision.description ?: 'Aucune justification.' }}</p>
                    </div>
                {% endif %}
                <div class="pm-section-head">
                    <h2>Historique des decisions</h2>
                    {% if can_manage_decisions %}
                        <a class="pm-btn pm-btn-primary" href="{{ path('decision_new', {projectId: project.id}) }}">Ajouter une validation</a>
                    {% endif %}
                </div>

                <details class="pm-history-toggle">
                    <summary class="pm-history-summary">
                        <span>Afficher l historique des decisions</span>
                        <span class="pm-history-count">{{ project.decisions|length }}</span>
                    </summary>

                    <div class="pm-decision-list">
                        {% for decision in project.decisions %}
                            <div class="pm-decision-item {% if latest_decision and latest_decision.id == decision.id %}pm-decision-item-current{% endif %}">
                                <div class="pm-section-head">
                                    <div>
                                        <strong>Statut : {{ decision.getDecisionTitleLabel() }}</strong>
                                        <span>{{ decision.decisionDate|date('d/m/Y') }}</span>
                                        <div class="pm-decision-meta">
                                            <span>Auteur : {{ decision.user ? decision.user.getPrenomUser() ~ ' ' ~ decision.user.getNomUser() : 'Non renseigne' }}</span>
                                            {% if latest_decision and latest_decision.id == decision.id %}
                                                <span class="pm-current-label">Version courante</span>
                                            {% endif %}
                                        </div>
                                    </div>
                                    {% if can_manage_decisions %}
                                        <div class="pm-card-actions">
                                            <a class="pm-btn pm-btn-secondary" href="{{ path('decision_edit', {id: decision.id}) }}">Nouvelle version</a>
                                            <form method="post" action="{{ path('decision_delete', {id: decision.id}) }}" onsubmit="return confirm('Supprimer cette decision ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_decision_' ~ decision.id) }}">
                                                <button class="pm-btn pm-btn-danger" type="submit">Supprimer</button>
                                            </form>
                                        </div>
                                    {% endif %}
                                </div>
                                <p>{{ decision.description ?: 'Aucune justification.' }}</p>
                            </div>
                        {% else %}
                            <p class="pm-empty-text">Aucune validation associee a ce projet.</p>
                        {% endfor %}
                    </div>
                </details>
            </article>
        </div>

        {% include 'shared/project_task_board.html.twig' with {
            project: project,
            task_board: task_board,
            task_form: task_form,
            editing_task: editing_task,
            can_manage_tasks: can_manage_tasks,
            can_move_tasks: can_move_tasks,
            task_readonly_hint: task_readonly_hint,
            management_route: 'project_back_manage'
        } %}

        <article class="pm-card pm-card-large pm-project-strategies">
            <div class="pm-section-head">
                <div>
                    <span class="pm-badge">Strategies liees</span>
                    <h2>Strategies rattachees au projet</h2>
                    <p class="pm-section-text">Consultez les strategies associees a ce projet. La decision d acceptation ou de refus se fait desormais cote client depuis la liste front des projets.</p>
                </div>
                <span class="pm-history-count">{{ project.strategies|length }}</span>
            </div>

            <div class="pm-strategy-list">
                {% for strategy in project.strategies %}
                    <section class="pm-strategy-card">
                        <div class="pm-strategy-main">
                            <div>
                                <div class="pm-strategy-topline">
                                    <h3>{{ strategy.nomStrategie }}</h3>
                                    <span class="pm-status pm-status-{{ strategy.statusCssClass }}">{{ strategy.statusLabel }}</span>
                                </div>
                            </div>
                        </div>

                        <div class="pm-strategy-meta">
                            <span><strong>Type :</strong> {{ strategy.type ?: 'Non precise' }}</span>
                            <span><strong>Duree :</strong> {{ strategy.DureeTerme }} mois</span>
                            <span><strong>Budget :</strong> {{ strategy.budgetTotal is not null ? strategy.budgetTotal|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</span>
                            <span><strong>Gain estime :</strong> {{ strategy.gainEstime is not null ? strategy.gainEstime ~ '%' : 'Non precise' }}</span>
                            <span><strong>Objectifs :</strong> {{ strategy.objectives|length }}</span>
                        </div>
                    </section>
                {% else %}
                    <p class="pm-empty-text">Aucune strategie n est encore rattachee a ce projet.</p>
                {% endfor %}
            </div>
        </article>
    </section>
{% endblock %}
