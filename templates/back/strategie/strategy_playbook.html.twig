<!DOCTYPE html>
<html lang="{{ document_language|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <title>{{ labels.document_title|default('Playbook Strategie') }}</title>
    <style>
        body {
            margin: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            color: #2f2419;
            background: #fffdfa;
            font-size: 13px;
            line-height: 1.55;
        }

        .page {
            padding: 34px 40px 52px;
        }

        .hero {
            padding: 28px 30px;
            border-radius: 24px;
            background: linear-gradient(140deg, #f7efe4 0%, #fff8ef 62%, #f4e4d2 100%);
            border: 1px solid #eadbc9;
            margin-bottom: 20px;
        }

        .eyebrow {
            margin: 0 0 10px;
            color: #9a7b61;
            text-transform: uppercase;
            font-size: 11px;
            letter-spacing: 0.12em;
            font-weight: 700;
        }

        h1 {
            margin: 0 0 12px;
            font-size: 30px;
            line-height: 1.18;
            color: #2c2016;
        }

        .hero-summary {
            margin: 0;
            font-size: 14px;
            color: #6c5847;
        }

        .status {
            display: inline-block;
            margin-top: 16px;
            padding: 7px 14px;
            border-radius: 999px;
            background: #f2e3d1;
            color: #7a563f;
            font-size: 12px;
            font-weight: 700;
        }

        .meta-grid,
        .dual-grid,
        .objective-grid,
        .phase-grid,
        .kpi-grid {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
        }

        .meta-grid td {
            width: 33.33%;
            vertical-align: top;
            padding-right: 12px;
        }

        .dual-grid td,
        .objective-grid td,
        .kpi-grid td {
            width: 50%;
            vertical-align: top;
            padding-right: 12px;
        }

        .phase-grid td {
            width: 33.33%;
            vertical-align: top;
            padding-right: 12px;
        }

        .card,
        .section-box {
            background: #ffffff;
            border: 1px solid #efe3d6;
            border-radius: 18px;
            box-sizing: border-box;
            page-break-inside: avoid;
        }

        .meta-card {
            padding: 14px 16px;
            min-height: 88px;
        }

        .meta-label,
        .pill {
            display: inline-block;
            color: #9a8a77;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .meta-label {
            margin-bottom: 8px;
        }

        .meta-value {
            font-size: 18px;
            font-weight: 700;
            color: #2f2419;
        }

        .meta-detail {
            margin-top: 6px;
            color: #8d7765;
            font-size: 12px;
        }

        .section {
            margin-top: 8px;
            margin-bottom: 18px;
        }

        .section h2 {
            margin: 0 0 10px;
            font-size: 18px;
            color: #6f4d38;
        }

        .section-box {
            padding: 18px 20px;
        }

        .panel-title {
            margin: 0 0 10px;
            font-size: 14px;
            color: #5a3d2c;
        }

        .paragraph {
            margin: 0;
            color: #4f3d30;
        }

        .subtle {
            color: #8a7564;
        }

        .note-title {
            margin: 0 0 8px;
            color: #6f4d38;
            font-size: 13px;
            font-weight: 700;
        }

        .note-copy {
            margin: 0;
            color: #5c493c;
        }

        .note-copy + .note-title {
            margin-top: 14px;
        }

        ul {
            margin: 0;
            padding-left: 18px;
        }

        li + li {
            margin-top: 8px;
        }

        .objective-card,
        .phase-card,
        .kpi-card {
            padding: 16px 18px;
        }

        .pill {
            padding: 5px 9px;
            border-radius: 999px;
            background: #f6eee4;
            color: #8f6d55;
            margin-bottom: 10px;
        }

        .objective-title,
        .phase-title,
        .kpi-name {
            margin: 0 0 8px;
            font-size: 15px;
            color: #2f2419;
        }

        .objective-copy,
        .phase-copy,
        .kpi-target,
        .kpi-cadence {
            margin: 0;
            color: #5b483a;
        }

        .phase-horizon {
            margin: 0 0 8px;
            color: #9a7b61;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            font-weight: 700;
        }

        .kpi-target {
            font-weight: 700;
            color: #3f2f24;
        }

        .kpi-cadence {
            margin-top: 6px;
            font-size: 12px;
            color: #8a7564;
        }

        .chart-box {
            padding-bottom: 22px;
        }

        .chart-summary {
            margin: 0 0 16px;
            color: #5a483a;
        }

        .chart-svg {
            display: block;
            width: 100%;
            height: auto;
        }

        .chart-grid {
            stroke: #e8dbcf;
            stroke-width: 1;
        }

        .chart-axis {
            stroke: #d7c4b2;
            stroke-width: 1.2;
        }

        .chart-axis-label {
            fill: #9a8a77;
            font-size: 11px;
        }

        .chart-area {
            fill: #ead8c6;
            opacity: 0.7;
        }

        .chart-line {
            fill: none;
            stroke: #8f5f46;
            stroke-width: 3;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .chart-point {
            fill: #8f5f46;
            stroke: #fffdfa;
            stroke-width: 2;
        }

        .chart-point-value {
            fill: #6f4d38;
            font-size: 11px;
            font-weight: 700;
            text-anchor: middle;
        }

        .chart-point-label {
            fill: #8a7564;
            font-size: 11px;
            text-anchor: middle;
        }

        .chart-footer {
            margin-top: 8px;
            overflow: hidden;
            color: #8a7564;
            font-size: 12px;
        }

        .chart-footer-left {
            float: left;
        }

        .chart-footer-right {
            float: right;
        }

        .footer {
            margin-top: 30px;
            padding-top: 16px;
            border-top: 1px solid #eadfd2;
            color: #8a7a64;
            font-size: 12px;
        }
    </style>
</head>
<body>
    {% set localizedStrategy = playbook_strategy|default({}) %}
    {% set localizedProject = playbook_project|default(null) %}
    {% set localizedObjectives = playbook_objectives|default([]) %}
    {% set projectProgress = project and project.avancementProj is not null ? project.avancementProj|number_format(0, ',', ' ') ~ '%' : labels.undefined %}
    {% set projectStatus = localizedProject ? localizedProject.status_label : labels.undefined %}
    {% set strategyOwner = localizedStrategy.owner|default(labels.undefined) %}
    {% set projectOwner = localizedProject ? localizedProject.owner : labels.undefined %}
    {% set durationLabel = strategy.DureeTerme is not null ? strategy.DureeTerme ~ ' ' ~ labels.duration_unit : labels.undefined %}
    {% set hasProjectContext = localizedProject and localizedProject.description %}
    {% set hasStrategyContext = localizedStrategy.news|default('') or localizedStrategy.justification|default('') %}

    <div class="page">
        <section class="hero">
            <p class="eyebrow">{{ labels.eyebrow }}</p>
            <h1>{{ localizedStrategy.name|default(labels.strategy_without_name) }}</h1>
            <p class="hero-summary">{{ content.executive_summary }}</p>
            <div class="status">{{ localizedStrategy.status_label|default(labels.undefined) }}</div>
        </section>

        <table class="meta-grid" role="presentation">
            <tr>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.associated_project }}</div>
                        <div class="meta-value">{{ localizedProject ? localizedProject.title : labels.no_project }}</div>
                        <div class="meta-detail">{{ labels.status }}: {{ projectStatus }}</div>
                    </div>
                </td>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.strategy_budget }}</div>
                        <div class="meta-value">{{ strategy.budgetTotal is not null ? strategy.budgetTotal|number_format(0, ',', ' ') ~ ' DT' : labels.undefined }}</div>
                        <div class="meta-detail">{{ labels.project_budget }}: {{ project and project.budgetProj is not null ? project.budgetProj|number_format(0, ',', ' ') ~ ' DT' : labels.undefined }}</div>
                    </div>
                </td>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.estimated_gain }}</div>
                        <div class="meta-value">{{ strategy.gainEstime is not null ? strategy.gainEstime ~ '%' : labels.undefined }}</div>
                        <div class="meta-detail">{{ labels.project_progress }}: {{ projectProgress }}</div>
                    </div>
                </td>
            </tr>
            <tr>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.target_duration }}</div>
                        <div class="meta-value">{{ durationLabel }}</div>
                        <div class="meta-detail">{{ labels.type }}: {{ localizedStrategy.type|default(labels.undefined) }}</div>
                    </div>
                </td>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.strategy_owner }}</div>
                        <div class="meta-value">{{ strategyOwner }}</div>
                        <div class="meta-detail">{{ labels.project_client }}: {{ projectOwner }}</div>
                    </div>
                </td>
                <td>
                    <div class="card meta-card">
                        <div class="meta-label">{{ labels.linked_objectives_count }}</div>
                        <div class="meta-value">{{ strategy.objectives|length }}</div>
                        <div class="meta-detail">{{ labels.generated_on }} {{ "now"|date("d/m/Y H:i") }}</div>
                    </div>
                </td>
            </tr>
        </table>

        {% if hasProjectContext or hasStrategyContext %}
            <section class="section">
                <h2>{{ labels.context_and_signals }}</h2>
                <table class="dual-grid" role="presentation">
                    <tr>
                        <td>
                            <div class="section-box">
                                <h3 class="note-title">{{ labels.project_context }}</h3>
                                <p class="note-copy">
                                    {{ hasProjectContext ? localizedProject.description : labels.no_project_description }}
                                </p>
                            </div>
                        </td>
                        <td>
                            <div class="section-box">
                                <h3 class="note-title">{{ labels.strategic_context }}</h3>
                                {% if localizedStrategy.news|default('') %}
                                    <p class="note-copy"><strong>{{ labels.strategic_context }}:</strong> {{ localizedStrategy.news }}</p>
                                {% endif %}
                                {% if localizedStrategy.justification|default('') %}
                                    <h3 class="note-title">{{ labels.justification }}</h3>
                                    <p class="note-copy">{{ localizedStrategy.justification }}</p>
                                {% elseif not localizedStrategy.news|default('') %}
                                    <p class="note-copy">{{ labels.no_strategic_context }}</p>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                </table>
            </section>
        {% endif %}

        <section class="section">
            <h2>{{ labels.strategic_diagnosis }}</h2>
            <div class="section-box">
                <p class="paragraph">{{ content.strategic_diagnosis }}</p>
            </div>
        </section>

        <section class="section">
            <table class="dual-grid" role="presentation">
                <tr>
                    <td>
                        <div class="section-box">
                            <h2>{{ labels.key_points }}</h2>
                            <ul>
                                {% for item in content.highlights %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </td>
                    <td>
                        <div class="section-box">
                            <h2>{{ labels.strategic_priorities }}</h2>
                            <ul>
                                {% for item in content.strategic_priorities %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </td>
                </tr>
            </table>
        </section>

        {% if localizedObjectives|length > 0 %}
            <section class="section">
                <h2>{{ labels.linked_objectives }}</h2>
                <table class="objective-grid" role="presentation">
                    {% for row in localizedObjectives|batch(2, null) %}
                        <tr>
                            {% for objective in row %}
                                <td>
                                    {% if objective %}
                                        <div class="card objective-card">
                                            <div class="pill">{{ objective.priority_badge }}</div>
                                            <h3 class="objective-title">{{ objective.name }}</h3>
                                            <p class="objective-copy">{{ objective.description }}</p>
                                        </div>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </table>
            </section>
        {% endif %}

        <section class="section">
            <h2>{{ labels.opportunities_and_value }}</h2>
            <div class="section-box">
                <ul>
                    {% for item in content.opportunities %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        </section>

        <section class="section">
            <h2>{{ labels.expected_outcome_projection }}</h2>
            <div class="section-box chart-box">
                <p class="chart-summary">{{ content.expected_outcome_summary }}</p>
                {% set chart = content.expected_outcome_chart %}
                <svg class="chart-svg" viewBox="0 0 {{ chart.width }} {{ chart.height }}" role="img" aria-label="{{ chart.aria_label }}">
                    {% for tick in chart.y_ticks %}
                        <line class="chart-grid" x1="{{ chart.plot_left }}" y1="{{ tick.y }}" x2="{{ chart.plot_right }}" y2="{{ tick.y }}"></line>
                        <text class="chart-axis-label" x="{{ chart.plot_left - 10 }}" y="{{ tick.y + 4 }}" text-anchor="end">{{ tick.label }}</text>
                    {% endfor %}

                    <line class="chart-axis" x1="{{ chart.plot_left }}" y1="{{ chart.plot_bottom }}" x2="{{ chart.plot_right }}" y2="{{ chart.plot_bottom }}"></line>
                    <polygon class="chart-area" points="{{ chart.area_points }}"></polygon>
                    <polyline class="chart-line" points="{{ chart.polyline_points }}"></polyline>

                    {% for point in chart.points %}
                        <circle class="chart-point" cx="{{ point.x }}" cy="{{ point.y }}" r="4.5"></circle>
                        <text class="chart-point-value" x="{{ point.x }}" y="{{ point.value_y }}">{{ point.value_label }}</text>
                        <text class="chart-point-label" x="{{ point.x }}" y="{{ chart.x_label_y }}">{{ point.period }}</text>
                    {% endfor %}
                </svg>
                <div class="chart-footer">
                    <span class="chart-footer-left">{{ labels.projected_start }}: {{ chart.start_value_label }}</span>
                    <span class="chart-footer-right">{{ labels.final_projection }}: {{ chart.final_value_label }}</span>
                </div>
            </div>
        </section>

        <section class="section">
            <h2>{{ labels.execution_roadmap }}</h2>
            <table class="phase-grid" role="presentation">
                <tr>
                    {% for phase in content.execution_phases %}
                        <td>
                            <div class="card phase-card">
                                <p class="phase-horizon">{{ phase.horizon }}</p>
                                <h3 class="phase-title">{{ phase.title }}</h3>
                                <p class="phase-copy">{{ phase.focus }}</p>
                            </div>
                        </td>
                    {% endfor %}
                </tr>
            </table>
        </section>

        <section class="section">
            <table class="dual-grid" role="presentation">
                <tr>
                    <td>
                        <div class="section-box">
                            <h2>{{ labels.risks_and_watchouts }}</h2>
                            <ul>
                                {% for item in content.risks %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </td>
                    <td>
                        <div class="section-box">
                            <h2>{{ labels.recommended_countermeasures }}</h2>
                            <ul>
                                {% for item in content.mitigation_actions %}
                                    <li>{{ item }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </td>
                </tr>
            </table>
        </section>

        <section class="section">
            <h2>{{ labels.recommended_action_plan }}</h2>
            <div class="section-box">
                <ul>
                    {% for item in content.actions %}
                        <li>{{ item }}</li>
                    {% endfor %}
                </ul>
            </div>
        </section>

        <section class="section">
            <h2>{{ labels.steering_indicators }}</h2>
            <table class="kpi-grid" role="presentation">
                {% for row in content.kpis|batch(2, null) %}
                    <tr>
                        {% for kpi in row %}
                            <td>
                                {% if kpi %}
                                    <div class="card kpi-card">
                                        <h3 class="kpi-name">{{ kpi.name }}</h3>
                                        <p class="kpi-target">{{ kpi.target }}</p>
                                        <p class="kpi-cadence">{{ labels.cadence }}: {{ kpi.cadence }}</p>
                                    </div>
                                {% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                {% endfor %}
            </table>
        </section>

        <div class="footer">
            {{ labels.generated_on }} {{ "now"|date("d/m/Y H:i") }} {{ labels.generated_from }}
        </div>
    </div>
</body>
</html>
