{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Detail de la strategie{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/back-strategy.css') }}">
     <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block body %}
<div class="show-container">
    <div class="show-header">
        <a href="{{ path('app_back_strategies') }}" class="back-link">
            <span class="material-symbols-outlined">arrow_back</span>
            Retour aux strategies
        </a>
        <div class="header-actions">
            <a href="{{ path('app_back_strategies_edit', {id: strategy.idStrategie}) }}" class="btn-edit">
                <span class="material-symbols-outlined">edit</span>
                Modifier
            </a>
            <form method="post" action="{{ path('app_back_strategies_delete', {id: strategy.idStrategie}) }}" onsubmit="return confirm('Supprimer cette strategie ?')" style="display: inline;">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ strategy.idStrategie) }}">
                <button type="submit" class="btn-delete">
                    <span class="material-symbols-outlined">delete</span>
                    Supprimer
                </button>
            </form>
        </div>
    </div>

    <div class="show-card">
        <div class="show-title">
            <h1>{{ strategy.nomStrategie }}</h1>
            <span class="status-badge {{ strategy.statusCssClass }}">
                {{ strategy.statusLabel }}
            </span>
        </div>

        <div class="show-grid">
            <div class="info-section">
                <h3>Informations generales</h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">Nom de la strategie</span>
                        <span class="info-value">{{ strategy.nomStrategie }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Duree</span>
                        <span class="info-value">{{ strategy.DureeTerme }} mois</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Type</span>
                        <span class="info-value">{{ strategy.type ?? 'Non defini' }}</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Date de creation</span>
                        <span class="info-value">{{ strategy.CreatedAtS ? strategy.CreatedAtS|date('d/m/Y H:i') : 'Non defini' }}</span>
                    </div>
                    {% if strategy.lockedAt %}
                    <div class="info-item">
                        <span class="info-label">Acceptee le</span>
                        <span class="info-value">{{ strategy.lockedAt|date('d/m/Y H:i') }}</span>
                    </div>
                    {% endif %}
                </div>
            </div>

            <div class="info-section">
                <h3>Aspects financiers</h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">Budget total</span>
                        <span class="info-value">{{ strategy.budgetTotal|number_format(0, ',', ' ') }} EUR</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Gain estime</span>
                        <span class="info-value {{ strategy.gainEstime >= 0 ? 'positive' : 'negative' }}">
                            {{ strategy.gainEstime >= 0 ? '+' : '' }}{{ strategy.gainEstime }}%
                        </span>
                    </div>
                </div>
            </div>

            <div class="info-section full-width">
                <h3>Justification</h3>
                <div class="info-text">
                    {{ strategy.justification ?: 'Aucune justification fournie' }}
                </div>
            </div>

            <div class="info-section full-width">
                <h3>Actualites liees</h3>
                <div class="info-text">
                    {{ strategy.news ?: 'Aucune actualite liee' }}
                </div>
            </div>

            <div class="info-section">
                <h3>Projet associe</h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">Projet</span>
                        <span class="info-value">{{ strategy.project ? strategy.project.idProj : 'Non associe' }}</span>
                    </div>
                </div>
            </div>

            <div class="info-section">
                <h3>Utilisateur associe</h3>
                <div class="info-list">
                    <div class="info-item">
                        <span class="info-label">Utilisateur</span>
                        <span class="info-value">{{ strategy.user ? strategy.user.idUser : 'Non associe' }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="show-actions">
            <a href="{{ path('app_back_strategies_edit', {id: strategy.idStrategie}) }}" class="btn-primary">Modifier la strategie</a>
        </div>
    </div>
</div>
{% endblock %}
