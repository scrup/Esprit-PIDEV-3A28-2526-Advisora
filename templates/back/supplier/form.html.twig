{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ page_badge|default('Gestion fournisseur') }}</span>
                <h1>{{ page_title }}</h1>
                <p>{{ page_message|default('Renseignez les informations du fournisseur.') }}</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ supplier.id ? path(back_route|default('supplier_back_manage'), {id: supplier.id}) : path('back_supplier_index') }}">Retour</a>
        </div>

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Etat fournisseur :</strong> {{ supplier.id ? supplier.getStatusLabel() : 'Sera determine apres enregistrement.' }}
                <br>
                <strong>Ressources rattachees :</strong> {{ supplier.id ? supplier.resources|length : 0 }}
            </div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', class: 'pm-validated-form', 'data-validation-form': 'supplier'}}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {{ forms.field(form.nomFr) }}
                    {{ forms.field(form.quantite) }}
                    {{ forms.field(form.fournisseur) }}
                    {{ forms.field(form.emailFr) }}
                    {{ forms.field(form.localisationFr) }}
                    {{ forms.field(form.numTelFr) }}
                </div>
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                    <a class="pm-btn pm-btn-secondary" href="{{ supplier.id ? path(back_route|default('supplier_back_manage'), {id: supplier.id}) : path('back_supplier_index') }}">Annuler</a>
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/project-form-validation.js') }}"></script>
{% endblock %}
