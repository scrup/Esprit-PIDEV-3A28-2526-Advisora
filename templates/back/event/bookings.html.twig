{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ 'event.back.bookings.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
    <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block body %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ 'event.back.common.badge'|trans }}</span>
                <h1>{{ 'event.back.bookings.heading'|trans }}</h1>
                <p>{{ 'event.back.bookings.subtitle'|trans }}</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ path('back_event_index') }}">{{ 'event.back.bookings.back_events'|trans }}</a>
        </div>

        {% include 'back/event/_module_nav.html.twig' %}

        <div class="pm-form-card pm-filter-card">
            <form method="get" class="pm-filter-grid">
                <div>
                    <label for="q">{{ 'event.back.common.search'|trans }}</label>
                    <input id="q" type="text" name="q" value="{{ filters.q }}" placeholder="{{ 'event.back.bookings.search_placeholder'|trans }}">
                </div>
                <div class="pm-filter-actions">
                    <button class="pm-btn pm-btn-primary" type="submit">{{ 'event.common.filter'|trans }}</button>
                    <a class="pm-btn pm-btn-secondary" href="{{ path('back_event_bookings') }}">{{ 'event.common.reset'|trans }}</a>
                </div>
            </form>
        </div>

        <section class="pm-grid">
            {% for booking in bookings %}
                <article class="pm-card">
                    <div class="pm-card-head">
                        <span class="pm-status pm-status-{{ booking.workflowStatusCssClass }}">{{ booking.workflowStatusLabel }}</span>
                        <span class="pm-meta">{{ 'event.back.bookings.booking_number'|trans }} #{{ booking.id }}</span>
                    </div>
                    <h2>{{ booking.event ? booking.event.title : ('event.common.event_unavailable'|trans) }}</h2>
                    <p>{{ booking.event and booking.event.description ? booking.event.description : ('event.common.no_description'|trans) }}</p>
                    <div class="pm-meta-list pm-meta-list-vertical">
                        <span><strong>{{ 'event.back.bookings.client'|trans }} :</strong> {{ booking.getClientDisplayName() }}</span>
                        <span><strong>{{ 'event.back.bookings.email'|trans }} :</strong> {{ booking.user ? booking.user.getEmailUser() : ('event.common.not_provided'|trans) }}</span>
                        <span><strong>{{ 'event.common.organizer'|trans }} :</strong> {{ booking.event ? booking.event.organizerName : ('event.common.not_provided'|trans) }}</span>
                        <span><strong>{{ 'event.back.bookings.booking_date'|trans }} :</strong> {{ booking.bookingDate ? booking.bookingDate|date('d/m/Y H:i') : ('event.common.not_provided_female'|trans) }}</span>
                        <span><strong>{{ 'event.back.manage.ticket_count'|trans }} :</strong> {{ booking.ticketCount }}</span>
                        <span><strong>{{ 'event.back.manage.total_stored'|trans }} :</strong> {{ booking.totalPrixBk|number_format(2, '.', ' ') }} TND</span>
                    </div>
                    <div class="pm-card-actions">
                        {% if booking.event %}
                            <a class="pm-btn pm-btn-primary" href="{{ path('event_back_manage', {id: booking.event.id}) }}">{{ 'event.back.bookings.open_event'|trans }}</a>
                            <a class="pm-btn pm-btn-secondary" href="{{ path('event_show', {id: booking.event.id}) }}">{{ 'event.back.index.view_front'|trans }}</a>
                        {% endif %}
                        {% if booking.isPending %}
                            <form method="post" action="{{ path('back_event_booking_accept', {id: booking.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('accept_booking_' ~ booking.id) }}">
                                <button class="pm-btn pm-btn-primary" type="submit">{{ 'event.back.manage.accept'|trans }}</button>
                            </form>
                            <form method="post" action="{{ path('back_event_booking_refuse', {id: booking.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('refuse_booking_' ~ booking.id) }}">
                                <button class="pm-btn pm-btn-danger" type="submit">{{ 'event.back.manage.refuse'|trans }}</button>
                            </form>
                        {% endif %}
                    </div>
                </article>
            {% else %}
                <div class="pm-empty">
                    <h2>{{ 'event.back.bookings.empty.title'|trans }}</h2>
                    <p>{{ 'event.back.bookings.empty.text'|trans }}</p>
                </div>
            {% endfor %}
        </section>
    </section>
{% endblock %}
