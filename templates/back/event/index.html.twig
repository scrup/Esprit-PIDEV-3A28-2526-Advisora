{% extends 'base_back.html.twig' %}

{% block title %}Advisora | {{ 'event.back.index.meta_title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
    <link rel="stylesheet" href="{{ asset('css/admin-custom.css') }}?v=20260415-users-v2">
{% endblock %}

{% block body %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ 'event.back.common.badge'|trans }}</span>
                <h1>{{ 'event.back.index.heading'|trans }}</h1>
                <p>{{ 'event.back.index.subtitle'|trans }}</p>
            </div>
            <div class="pm-card-actions">
                <a class="pm-btn pm-btn-primary" href="{{ path('event_new') }}">{{ 'event.back.index.add_event'|trans }}</a>
                <a class="pm-btn pm-btn-secondary" href="{{ path('app_back') }}">{{ 'event.back.index.back_dashboard'|trans }}</a>
            </div>
        </div>

        {% include 'back/event/_module_nav.html.twig' %}

        <div class="pm-form-card pm-filter-card">
            <form method="get" class="pm-filter-grid">
                <div>
                    <label for="q">{{ 'event.back.common.search'|trans }}</label>
                    <input id="q" type="text" name="q" value="{{ filters.q }}" placeholder="{{ 'event.back.index.search_placeholder'|trans }}">
                </div>
                <div>
                    <label for="manager">{{ 'event.back.common.manager'|trans }}</label>
                    <input id="manager" type="text" name="manager" value="{{ filters.manager }}" placeholder="{{ 'event.back.index.manager_placeholder'|trans }}">
                </div>
                <div class="pm-filter-actions">
                    <button class="pm-btn pm-btn-primary" type="submit">{{ 'event.common.filter'|trans }}</button>
                    <a class="pm-btn pm-btn-secondary" href="{{ path('back_event_index') }}">{{ 'event.common.reset'|trans }}</a>
                </div>
            </form>
        </div>

        <section class="pm-grid">
            {% for event in events %}
                <article class="pm-card">
                    <div class="pm-card-head">
                        <span class="pm-status pm-status-{{ event.getTimelineStatus() }}">{{ event.getTimelineLabel() }}</span>
                        <span class="pm-meta">{{ 'event.common.event_number'|trans }} #{{ event.id }}</span>
                    </div>
                    <h2>{{ event.title }}</h2>
                    <p>{{ event.description ?: ('event.common.no_description'|trans) }}</p>
                    <div class="pm-meta-list pm-meta-list-vertical">
                        <span><strong>{{ 'event.common.organizer'|trans }} :</strong> {{ event.organizerName ?: ('event.common.not_provided'|trans) }}</span>
                        <span><strong>{{ 'event.common.location'|trans }} :</strong> {{ event.location ?: ('event.common.not_provided'|trans) }}</span>
                        <span><strong>{{ 'event.back.common.start'|trans }} :</strong> {{ event.startDate ? event.startDate|date('d/m/Y H:i') : ('event.common.not_provided'|trans) }}</span>
                        <span><strong>{{ 'event.back.common.end'|trans }} :</strong> {{ event.endDate ? event.endDate|date('d/m/Y H:i') : ('event.common.not_provided_female'|trans) }}</span>
                        <span><strong>{{ 'event.back.common.manager'|trans }} :</strong> {{ event.getManagerDisplayName() }}</span>
                        <span><strong>{{ 'event.back.common.reserved_tickets'|trans }} :</strong> {{ event.reservedTickets }}</span>
                    </div>
                    <div class="pm-card-actions">
                        <a class="pm-btn pm-btn-primary" href="{{ path('event_back_manage', {id: event.id}) }}">{{ 'event.common.manage'|trans }}</a>
                        <a class="pm-btn pm-btn-secondary" href="{{ path('event_edit', {id: event.id}) }}">{{ 'event.common.edit'|trans }}</a>
                        <a class="pm-btn pm-btn-secondary" href="{{ path('event_show', {id: event.id}) }}">{{ 'event.back.index.view_front'|trans }}</a>
                        <form method="post" action="{{ path('event_delete', {id: event.id}) }}" onsubmit="return confirm('{{ 'event.back.common.confirm_delete_event'|trans }}');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                            <button class="pm-btn pm-btn-danger" type="submit">{{ 'event.common.delete'|trans }}</button>
                        </form>
                    </div>
                </article>
            {% else %}
                <div class="pm-empty">
                    <h2>{{ 'event.back.index.empty.title'|trans }}</h2>
                    <p>{{ 'event.back.index.empty.text'|trans }}</p>
                </div>
            {% endfor %}
        </section>
    </section>
{% endblock %}
