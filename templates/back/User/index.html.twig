{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Gestion des utilisateurs{% endblock %}

{% block body %}
<section class="back-users-shell">
    <div class="pm-admin-header">
        <div class="back-users-title">
            <span class="pm-badge">Back office</span>
            <h1>Gestion des utilisateurs</h1>
            <p>Gerez les comptes, les roles et les acces de la plateforme avec la meme interface que le reste du back office.</p>
        </div>
        <div class="pm-card-actions">
            <a href="{{ path('app_back') }}" class="pm-btn pm-btn-secondary">Retour au tableau de bord</a>
            <a href="{{ path('back_user_new') }}" class="pm-btn pm-btn-primary">Ajouter un utilisateur</a>
        </div>
    </div>

    <div class="back-users-toolbar">
        <div class="back-user-search">
            <label for="userSearch">Recherche locale</label>
            <input type="text" id="userSearch" placeholder="Rechercher par nom..." />
        </div>

        <form method="get" action="{{ path('back_user_index') }}" class="back-user-sort">
            <label for="sort">Tri principal</label>
            <select id="sort" name="sort" onchange="this.form.submit()">
                <option value="idUser" {{ currentSort == 'idUser' ? 'selected' : '' }}>Par ID</option>
                <option value="roleUser" {{ currentSort == 'roleUser' ? 'selected' : '' }}>Par role</option>
                <option value="dateNUser" {{ currentSort == 'dateNUser' ? 'selected' : '' }}>Par date de naissance</option>
            </select>
            <input type="hidden" name="direction" value="{{ nextDirection }}">
        </form>

        <div class="back-user-stat">
            <label>Tri actuel</label>
            <strong>
                {% if currentSort == 'roleUser' %}
                    Role
                {% elseif currentSort == 'dateNUser' %}
                    Date de naissance
                {% else %}
                    ID
                {% endif %}
            </strong>
            <span class="back-users-summary">{{ currentDirection }}</span>
        </div>

        <div class="back-user-stat">
            <label>Total</label>
            <strong>{{ users|length }} utilisateur(s)</strong>
            <span class="back-users-summary">Vue synchronisee avec le back office</span>
        </div>
    </div>

    <div class="back-user-table-shell">
        <table class="back-user-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom complet</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Date naissance</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr class="back-user-row user-row">
                        <td>#{{ user.idUser }}</td>
                        <td class="user-name">
                            <span class="back-user-name">{{ user.prenomUser }} {{ user.nomUser }}</span>
                        </td>
                        <td>{{ user.EmailUser }}</td>
                        <td>
                            {% if user.roleUser|upper == 'ADMIN' %}
                                <span class="back-role-badge back-role-admin">ADMIN</span>
                            {% elseif user.roleUser|upper == 'GERANT' %}
                                <span class="back-role-badge back-role-gerant">GERANT</span>
                            {% else %}
                                <span class="back-role-badge back-role-client">CLIENT</span>
                            {% endif %}
                        </td>
                        <td>{{ user.dateNUser ? user.dateNUser|date('d/m/Y') : '-' }}</td>
                        <td>
                            <div class="back-user-table-actions">
                                <a href="{{ path('back_user_edit', {idUser: user.idUser}) }}" class="back-icon-button" title="Modifier">
                                    <i class="fas fa-pen"></i>
                                </a>
                                <form
                                    method="post"
                                    action="{{ path('back_user_delete', {idUser: user.idUser}) }}"
                                    class="back-icon-button-form"
                                    onsubmit="return confirm('Supprimer cet utilisateur ?');"
                                >
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.idUser) }}">
                                    <button type="submit" class="back-icon-button back-icon-button-danger" title="Supprimer">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="back-users-summary" style="text-align: center; padding: 1.5rem;">
                            Aucun utilisateur trouve.
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const search = document.getElementById('userSearch');

            if (!search) {
                return;
            }

            search.addEventListener('keyup', function () {
                const filter = this.value.toLowerCase();

                document.querySelectorAll('.user-row').forEach(function (row) {
                    const text = row.querySelector('.user-name')?.textContent.toLowerCase() || '';
                    row.style.display = text.includes(filter) ? '' : 'none';
                });
            });
        });
    </script>
{% endblock %}
