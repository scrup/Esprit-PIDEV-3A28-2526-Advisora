{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Tableau de bord{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/back-dashboard.css') }}">
{% endblock %}

{% block body %}
<div class="dashboard-container">
    <div class="dashboard-header">
        <div class="welcome-section">
            <h1>Bonjour, {{ app.user ? app.user.getPrenomUser() : 'Equipe' }} <span class="wave">👋</span></h1>
            <p>Voici ce qui se passe avec vos projets aujourd'hui</p>
        </div>
        <div class="date-badge">
            <i class="fas fa-calendar-alt"></i>
            <span id="currentDate"></span>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-folder-open"></i></div>
            <div class="stat-info">
                <h3>Projets actifs</h3>
                <div class="stat-value"><span class="counter" data-target="{{ total_projects }}">0</span></div>
                <span class="stat-trend"><i class="fas fa-clock"></i> {{ pending_projects }} en attente</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
            <div class="stat-info">
                <h3>Projets acceptes</h3>
                <div class="stat-value"><span class="counter" data-target="{{ accepted_projects }}">0</span></div>
                <span class="stat-trend"><i class="fas fa-check"></i> Valides par decision</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-coins"></i></div>
            <div class="stat-info">
                <h3>Investissement total</h3>
                <div class="stat-value"><span class="counter" data-target="2400000">0</span><span> DT</span></div>
                <span class="stat-trend"><i class="fas fa-chart-simple"></i> +12% croissance</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="fas fa-gavel"></i></div>
            <div class="stat-info">
                <h3>Decisions</h3>
                <div class="stat-value"><span class="counter" data-target="{{ total_decisions }}">0</span></div>
                <span class="stat-trend"><i class="fas fa-ban"></i> {{ refused_projects }} projets refuses</span>
            </div>
        </div>
    </div>

    <div class="two-columns">
        <div>
            <div class="card-panel performance-panel">
                <div class="panel-header performance-header">
                    <div>
                        <h3><i class="fas fa-chart-line"></i> Performance strategique</h3>
                        <p class="performance-subtitle">Barres: strategies acceptees par date de validation . Courbe: taux de reussite calcule avec les strategies acceptees et le total des strategies refusees.</p>
                    </div>
                    <div class="performance-summary">
                        <span class="performance-pill">
                            <strong>{{ strategy_acceptance_timeline.accepted_total }}</strong>
                            Acceptees
                        </span>
                        <span class="performance-pill">
                            <strong>{{ strategy_acceptance_timeline.refused_total }}</strong>
                            Refusees
                        </span>
                        <span class="performance-pill performance-pill-highlight">
                            <strong>{{ strategy_acceptance_timeline.latest_success_rate|number_format(1, '.', ' ') }}%</strong>
                            Taux de reussite
                        </span>
                    </div>
                </div>

                {% if strategy_acceptance_timeline.labels is not empty %}
                    <div
                        class="performance-chart-shell"
                        id="strategyPerformanceCard"
                        data-chart="{{ strategy_acceptance_timeline|json_encode|e('html_attr') }}"
                    >
                        <canvas id="strategyPerformanceChart"></canvas>
                    </div>
                    <p class="performance-note">
                        Le taux de reussite est calcule avec le cumul des strategies acceptees par datees face au total des strategies refusees.
                    </p>
                {% else %}
                    <div class="performance-empty">
                        <i class="fas fa-chart-line"></i>
                        <div>
                            <strong>Aucune strategie acceptee datee pour le moment</strong>
                            <p>La courbe apparaitra des que des strategies acceptees auront une date .</p>
                        </div>
                    </div>
                {% endif %}
            </div>

            <div class="card-panel">
                <div class="panel-header">
                    <h3><i class="fas fa-chart-pie"></i> Repartition des investissements</h3>
                    <a href="#" class="view-link">Details</a>
                </div>
                <div class="investment-breakdown">
                    <div class="investment-chart">
                        <canvas id="investmentChart" width="120" height="120"></canvas>
                    </div>
                    <div class="investment-legend">
                        <div>
                            <span class="legend-color" style="background: var(--primary-terracotta);"></span>
                            <span>Actions</span>
                            <strong style="margin-left: auto;">45%</strong>
                        </div>
                        <div>
                            <span class="legend-color" style="background: var(--sage-green);"></span>
                            <span>Obligations</span>
                            <strong style="margin-left: auto;">25%</strong>
                        </div>
                        <div>
                            <span class="legend-color" style="background: var(--warm-beige);"></span>
                            <span>Immobilier</span>
                            <strong style="margin-left: auto;">20%</strong>
                        </div>
                        <div>
                            <span class="legend-color" style="background: #A56143;"></span>
                            <span>Crypto</span>
                            <strong style="margin-left: auto;">10%</strong>
                        </div>
                    </div>
                </div>
                <div class="investment-footer">
                    <i class="fas fa-chart-line"></i> Performance: <strong class="positive">+15.3%</strong>
                </div>
            </div>
        </div>

        <div>
            <div class="card-panel">
                <div class="panel-header">
                    <h3><i class="fas fa-rocket"></i> Apercu des projets</h3>
                    <a href="#" class="view-link">Voir tous</a>
                </div>
                <div class="insight-list">
                    <div class="insight-item">
                        <span class="project-name">Plateforme e-commerce</span>
                        <div class="progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 80%"></div>
                            </div>
                            <span class="progress-percent">80%</span>
                        </div>
                    </div>
                    <div class="insight-item">
                        <span class="project-name">Application mobile</span>
                        <div class="progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 40%"></div>
                            </div>
                            <span class="progress-percent">40%</span>
                        </div>
                    </div>
                    <div class="insight-item">
                        <span class="project-name">Integration IA</span>
                        <div class="progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 20%"></div>
                            </div>
                            <span class="progress-percent">20%</span>
                        </div>
                    </div>
                    <div class="insight-item">
                        <span class="project-name">Dashboard financier</span>
                        <div class="progress">
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: 60%"></div>
                            </div>
                            <span class="progress-percent">60%</span>
                        </div>
                    </div>
                </div>
                <div class="insight-footer">
                    <i class="fas fa-chart-pie"></i> Avancement global: <strong>50%</strong> · 4 projets actifs
                    <div class="project-timeline">
                        <span><i class="fas fa-calendar-check"></i> Echeance: 15 mai</span>
                    </div>
                </div>
            </div>

            <div class="card-panel">
                <div class="panel-header">
                    <h3><i class="fas fa-calendar-alt"></i> Evenements a venir</h3>
                    <a href="#" class="view-link">Voir tout</a>
                </div>
                <div class="events-list">
                    <div class="event-item">
                        <div class="event-date">
                            <span>15</span>
                            <span>AVR</span>
                        </div>
                        <div class="event-info">
                            <strong>Webinaire: Strategies d'investissement 2025</strong>
                            <p>15h00 - En ligne</p>
                        </div>
                        <button class="event-btn">S'inscrire</button>
                    </div>
                    <div class="event-item">
                        <div class="event-date">
                            <span>22</span>
                            <span>AVR</span>
                        </div>
                        <div class="event-info">
                            <strong>Atelier: Optimisation fiscale</strong>
                            <p>09h00 - Tunis</p>
                        </div>
                        <button class="event-btn">S'inscrire</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="full-width-card">
        <div class="panel-header">
            <h3><i class="fas fa-book-open"></i> Ressources recentes</h3>
            <a href="#" class="view-link">Voir tout</a>
        </div>
        <div class="resources-list">
            <div class="resource-item">
                <div class="resource-icon">
                    <i class="fas fa-file-pdf"></i>
                </div>
                <div class="resource-info">
                    <strong>Guide investissement 2025</strong>
                    <p>PDF · 2.4 MB</p>
                </div>
                <button class="resource-btn">
                    <i class="fas fa-download"></i>
                </button>
            </div>
            <div class="resource-item">
                <div class="resource-icon">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="resource-info">
                    <strong>Rapport trimestriel Q1</strong>
                    <p>Excel · 1.8 MB</p>
                </div>
                <button class="resource-btn">
                    <i class="fas fa-download"></i>
                </button>
            </div>
            <div class="resource-item">
                <div class="resource-icon">
                    <i class="fas fa-video"></i>
                </div>
                <div class="resource-info">
                    <strong>Enregistrement webinaire</strong>
                    <p>MP4 · 500 MB</p>
                </div>
                <button class="resource-btn">
                    <i class="fas fa-download"></i>
                </button>
            </div>
        </div>

        <div class="quick-actions">
            <button class="action-btn"><i class="fas fa-chart-line"></i> Generer rapport</button>
            <button class="action-btn"><i class="fas fa-calendar-plus"></i> Planifier reunion</button>
            <button class="action-btn"><i class="fas fa-download"></i> Exporter donnees</button>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="{{ asset('js/back-dashboard.js') }}"></script>
{% endblock %}
