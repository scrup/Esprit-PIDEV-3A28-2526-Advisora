{% extends 'base_back.html.twig' %}

{% block title %}{{ 'back.dashboard.meta.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/back-dashboard.css') }}?v=20260411-shell-v2">
{% endblock %}

{% block body %}
<section class="dashboard-shell">
    <header class="dashboard-hero">
        <div class="dashboard-hero-copy">
            <span class="dashboard-eyebrow">{{ 'back.dashboard.hero.eyebrow'|trans }}</span>
            <h1>{{ 'back.dashboard.hero.title'|trans }}</h1>
            <p>{{ 'back.dashboard.hero.description'|trans }}</p>
        </div>

        <div class="dashboard-hero-side">
            <label class="dashboard-search" aria-label="{{ 'back.dashboard.search.aria'|trans }}">
                <i class="fas fa-search"></i>
                <input type="search" placeholder="{{ 'back.dashboard.search.placeholder'|trans }}" />
            </label>

            <div class="dashboard-hero-meta">
                <div class="dashboard-date-card">
                    <span>{{ 'back.dashboard.today'|trans }}</span>
                    <strong id="currentDate"></strong>
                </div>
                <div class="dashboard-user-card">
                    <span class="dashboard-user-avatar">{{ app.user ? app.user.getPrenomUser()|slice(0, 1)|upper : 'A' }}</span>
                    <div>
                        <strong>{{ app.user ? app.user.getPrenomUser() : 'Equipe' }}</strong>
                        <span>{{ 'back.dashboard.user_area'|trans }}</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="executive-grid">
        <article class="executive-card">
            <span class="executive-icon"><i class="fas fa-briefcase"></i></span>
            <div class="executive-copy">
                <span class="executive-label">{{ 'back.dashboard.cards.active_projects.label'|trans }}</span>
                <strong>{{ total_projects }}</strong>
                <span class="executive-meta">{{ accepted_projects }} {{ 'back.dashboard.cards.active_projects.meta'|trans }}</span>
            </div>
        </article>

        <article class="executive-card">
            <span class="executive-icon executive-icon-warm"><i class="fas fa-hourglass-half"></i></span>
            <div class="executive-copy">
                <span class="executive-label">{{ 'back.dashboard.cards.pending_projects.label'|trans }}</span>
                <strong>{{ pending_projects }}</strong>
                <span class="executive-meta">{{ refused_projects }} {{ 'back.dashboard.cards.pending_projects.meta'|trans }}</span>
            </div>
        </article>

        <article class="executive-card">
            <span class="executive-icon executive-icon-cool"><i class="fas fa-gavel"></i></span>
            <div class="executive-copy">
                <span class="executive-label">{{ 'back.dashboard.cards.decisions.label'|trans }}</span>
                <strong>{{ total_decisions }}</strong>
                <span class="executive-meta">{{ 'back.dashboard.cards.decisions.meta'|trans }}</span>
            </div>
        </article>

        <article class="executive-card">
            <span class="executive-icon executive-icon-emerald"><i class="fas fa-wallet"></i></span>
            <div class="executive-copy">
                <span class="executive-label">{{ 'back.dashboard.cards.volume.label'|trans }}</span>
                <strong>{{ investment_metrics.total_amount|number_format(0, '.', ' ') }} DT</strong>
                <span class="executive-meta">{{ investment_metrics.count }} {{ 'back.dashboard.cards.volume.meta'|trans }}</span>
            </div>
        </article>
    </div>

    <div class="dashboard-core-grid">
        <article class="dashboard-panel dashboard-panel-main">
            <div class="panel-header">
                <div>
                    <span class="panel-eyebrow">{{ 'back.dashboard.strategy_analysis.eyebrow'|trans }}</span>
                    <h2>{{ 'back.dashboard.strategy_analysis.title'|trans }}</h2>
                    <p>{{ 'back.dashboard.strategy_analysis.description'|trans }}</p>
                </div>
                <div class="panel-badges">
                    <span>{{ strategy_acceptance_timeline.accepted_total }} {{ 'back.dashboard.strategy_analysis.accepted'|trans }}</span>
                    <span>{{ strategy_acceptance_timeline.refused_total }} {{ 'back.dashboard.strategy_analysis.refused'|trans }}</span>
                    <span class="panel-badge-strong">{{ strategy_acceptance_timeline.latest_success_rate|number_format(1, '.', ' ') }}% {{ 'back.dashboard.strategy_analysis.success'|trans }}</span>
                </div>
            </div>

            {% if strategy_acceptance_timeline.labels is not empty %}
                <div
                    class="performance-chart-shell"
                    id="strategyPerformanceCard"
                    data-chart="{{ strategy_acceptance_timeline|json_encode|e('html_attr') }}"
                >
                    <canvas id="strategyPerformanceChart"></canvas>
                </div>
            {% else %}
                <div class="dashboard-empty-state">
                    <i class="fas fa-chart-line"></i>
                    <div>
                        <strong>{{ 'back.dashboard.strategy_analysis.empty_title'|trans }}</strong>
                        <p>{{ 'back.dashboard.strategy_analysis.empty_text'|trans }}</p>
                    </div>
                </div>
            {% endif %}
        </article>

        <div class="dashboard-side-stack">
            <article class="dashboard-panel">
                <div class="panel-header panel-header-compact">
                    <div>
                        <span class="panel-eyebrow">{{ 'back.dashboard.investment_summary.eyebrow'|trans }}</span>
                        <h2>{{ 'back.dashboard.investment_summary.title'|trans }}</h2>
                    </div>
                    <span class="panel-inline-indicator">{{ investment_metrics.largest_ticket|number_format(0, '.', ' ') }} DT {{ 'back.dashboard.investment_summary.max'|trans }}</span>
                </div>

                <div class="balance-value">{{ investment_metrics.total_amount|number_format(0, '.', ' ') }} DT</div>

                <div class="balance-grid">
                    <div class="balance-tile">
                        <span>{{ 'back.dashboard.investment_summary.tiles.investments'|trans }}</span>
                        <strong>{{ investment_metrics.count }}</strong>
                    </div>
                    <div class="balance-tile">
                        <span>{{ 'back.dashboard.investment_summary.tiles.events'|trans }}</span>
                        <strong>{{ upcoming_events_count }}</strong>
                    </div>
                    <div class="balance-tile">
                        <span>{{ 'back.dashboard.investment_summary.tiles.resources_available'|trans }}</span>
                        <strong>{{ resource_metrics.available }}</strong>
                    </div>
                    <div class="balance-tile">
                        <span>{{ 'back.dashboard.investment_summary.tiles.resources_linked'|trans }}</span>
                        <strong>{{ resource_metrics.linked }}</strong>
                    </div>
                </div>
            </article>

            <article class="dashboard-panel">
                <div class="panel-header panel-header-compact">
                    <div>
                        <span class="panel-eyebrow">{{ 'back.dashboard.allocation.eyebrow'|trans }}</span>
                        <h2>{{ 'back.dashboard.allocation.title'|trans }}</h2>
                    </div>
                </div>

                {% if investment_metrics.distribution is not empty %}
                    <div class="allocation-shell" data-donut="{{ investment_metrics.distribution|json_encode|e('html_attr') }}">
                        <div class="allocation-chart">
                            <canvas id="investmentChart" width="170" height="170"></canvas>
                        </div>
                        <div class="allocation-legend">
                            {% for item in investment_metrics.distribution %}
                                <div>
                                    <span class="legend-color legend-color-{{ loop.index0 }}"></span>
                                    <span>{{ item.label }}</span>
                                    <strong>{{ item.value|number_format(0, '.', ' ') }}</strong>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <p class="dashboard-empty-copy">{{ 'back.dashboard.allocation.empty'|trans }}</p>
                {% endif %}
            </article>
        </div>
    </div>

    <div class="operations-grid">
        <article class="dashboard-panel">
            <div class="panel-header panel-header-compact">
                <div>
                    <span class="panel-eyebrow">{{ 'back.dashboard.projects.eyebrow'|trans }}</span>
                    <h2>{{ 'back.dashboard.projects.title'|trans }}</h2>
                </div>
                <a href="{{ path('back_project_index') }}" class="panel-link">{{ 'back.dashboard.projects.link'|trans }}</a>
            </div>

            {% if latest_projects is not empty %}
                <div class="stack-list">
                    {% for project in latest_projects %}
                        <a class="stack-item" href="{{ path('project_back_manage', {id: project.id}) }}">
                            <div class="stack-copy">
                                <strong>{{ project.title ?: 'Projet sans titre' }}</strong>
                                <span>{{ project.legacyType ?: 'Type non precise' }} - {{ project.statusLabel }}</span>
                            </div>
                            <div class="stack-metric">
                                <span>{{ 'back.dashboard.projects.progress'|trans }}</span>
                                <strong>{{ project.avancementProj|default(0)|number_format(0, '.', ' ') }}%</strong>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="dashboard-empty-copy">{{ 'back.dashboard.projects.empty'|trans }}</p>
            {% endif %}
        </article>

        <article class="dashboard-panel">
            <div class="panel-header panel-header-compact">
                <div>
                    <span class="panel-eyebrow">{{ 'back.dashboard.decisions.eyebrow'|trans }}</span>
                    <h2>{{ 'back.dashboard.decisions.title'|trans }}</h2>
                </div>
                <a href="{{ path('back_project_overview') }}" class="panel-link">{{ 'back.dashboard.decisions.link'|trans }}</a>
            </div>

            {% if latest_decisions is not empty %}
                <div class="stack-list">
                    {% for decision in latest_decisions %}
                        <a class="stack-item" href="{{ path('project_back_manage', {id: decision.project.id}) }}">
                            <div class="stack-copy">
                                <strong>{{ decision.project ? decision.project.title : 'Projet indisponible' }}</strong>
                                <span>{{ decision.decisionDate ? decision.decisionDate|date('d/m/Y') : 'Non datee' }}</span>
                            </div>
                            <span class="status-pill status-pill-{{ decision.decisionTitle|default('pending') }}">{{ decision.decisionTitleLabel }}</span>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="dashboard-empty-copy">{{ 'back.dashboard.decisions.empty'|trans }}</p>
            {% endif %}
        </article>

        <article class="dashboard-panel">
            <div class="panel-header panel-header-compact">
                <div>
                    <span class="panel-eyebrow">{{ 'back.dashboard.events.eyebrow'|trans }}</span>
                    <h2>{{ 'back.dashboard.events.title'|trans }}</h2>
                </div>
                <a href="{{ path('back_event_index') }}" class="panel-link">{{ 'back.dashboard.events.link'|trans }}</a>
            </div>

            {% if upcoming_events is not empty %}
                <div class="stack-list">
                    {% for event in upcoming_events %}
                        <a class="stack-item" href="{{ path('event_back_manage', {id: event.id}) }}">
                            <div class="stack-copy">
                                <strong>{{ event.title ?: 'Evenement' }}</strong>
                                <span>{{ event.location ?: 'Lieu non precise' }} - {{ event.timelineLabel }}</span>
                            </div>
                            <div class="stack-metric">
                                <span>{{ 'back.dashboard.events.start'|trans }}</span>
                                <strong>{{ event.startDate ? event.startDate|date('d M H:i') : '--' }}</strong>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="dashboard-empty-copy">{{ 'back.dashboard.events.empty'|trans }}</p>
            {% endif %}
        </article>

        <article class="dashboard-panel">
            <div class="panel-header panel-header-compact">
                <div>
                    <span class="panel-eyebrow">{{ 'back.dashboard.resources.eyebrow'|trans }}</span>
                    <h2>{{ 'back.dashboard.resources.title'|trans }}</h2>
                </div>
                <a href="{{ path('back_resource_dashboard') }}" class="panel-link">{{ 'back.dashboard.resources.link'|trans }}</a>
            </div>

            {% if recent_resources is not empty %}
                <div class="stack-list">
                    {% for resource in recent_resources %}
                        <a class="stack-item" href="{{ path('resource_back_manage', {id: resource.id}) }}">
                            <div class="stack-copy">
                                <strong>{{ resource.name ?: 'Ressource' }}</strong>
                                <span>{{ resource.statusLabel }} - {{ resource.getSupplierDisplayName() }}</span>
                            </div>
                            <div class="stack-metric">
                                <span>{{ 'back.dashboard.resources.stock'|trans }}</span>
                                <strong>{{ resource.quantity ?? 0 }}</strong>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            {% else %}
                <p class="dashboard-empty-copy">{{ 'back.dashboard.resources.empty'|trans }}</p>
            {% endif %}
        </article>
    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="{{ asset('js/back-dashboard.js') }}?v=20260411-shell-v2"></script>
{% endblock %}