{% extends 'base_back.html.twig' %}

{% block title %}Advisora | Tableau de bord{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/back-dashboard.css') }}">
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% block body %}
    <div class="dashboard-container">
        <div class="dashboard-header">
            <div class="welcome-section">
                <h1>Bonjour, {{ app.user ? app.user.getPrenomUser() : 'Equipe' }}</h1>
                <p>Voici la situation actuelle des projets et des decisions du module de gestion.</p>
            </div>
            <div class="date-badge">
                <i class="fas fa-calendar-alt"></i>
                <span id="currentDate"></span>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-folder-open"></i></div>
                <div class="stat-info">
                    <h3>Total projets</h3>
                    <div class="stat-value">{{ total_projects }}</div>
                    <span class="stat-trend">Tous les projets du module</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-hourglass-half"></i></div>
                <div class="stat-info">
                    <h3>Projets en attente</h3>
                    <div class="stat-value">{{ pending_projects }}</div>
                    <span class="stat-trend">A traiter par le back office</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
                <div class="stat-info">
                    <h3>Projets acceptes</h3>
                    <div class="stat-value">{{ accepted_projects }}</div>
                    <span class="stat-trend">Valides par decision recente</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon"><i class="fas fa-gavel"></i></div>
                <div class="stat-info">
                    <h3>Decisions</h3>
                    <div class="stat-value">{{ total_decisions }}</div>
                    <span class="stat-trend">{{ refused_projects }} projets refuses</span>
                </div>
            </div>
        </div>

        <div class="two-columns">
            <div>
                <div class="card-panel">
                    <div class="panel-header">
                        <h3><i class="fas fa-clock"></i> Derniers projets soumis</h3>
                        <a href="{{ path('back_project_index') }}" class="view-link">Voir tous</a>
                    </div>
                    <div class="dashboard-list">
                        {% for project in latest_projects %}
                            <a class="dashboard-list-item" href="{{ path('project_back_manage', {id: project.id}) }}">
                                <div>
                                    <strong>{{ project.title }}</strong>
                                    <p>{{ project.user ? project.user.getPrenomUser() ~ ' ' ~ project.user.getNomUser() : 'Non assigne' }}</p>
                                </div>
                                <div class="dashboard-list-meta">
                                    <span class="pm-status pm-status-{{ project.status|lower }}">{{ project.getStatusLabel() }}</span>
                                    <span>{{ project.startDate ? project.startDate|date('d/m/Y') : '' }}</span>
                                </div>
                            </a>
                        {% else %}
                            <p class="dashboard-empty">Aucun projet disponible.</p>
                        {% endfor %}
                    </div>
                </div>

                <div class="card-panel">
                    <div class="panel-header">
                        <h3><i class="fas fa-sliders-h"></i> Actions rapides</h3>
                    </div>
                    <div class="quick-actions quick-actions-start">
                        <a href="{{ path('back_project_index') }}" class="action-btn"><i class="fas fa-folder-open"></i> Gerer les projets</a>
                        <a href="{{ path('project_index') }}" class="action-btn"><i class="fas fa-eye"></i> Voir le front</a>
                    </div>
                </div>
            </div>

            <div>
                <div class="card-panel">
                    <div class="panel-header">
                        <h3><i class="fas fa-history"></i> Dernieres decisions</h3>
                        <a href="{{ path('back_project_index') }}" class="view-link">Acceder aux projets</a>
                    </div>
                    <div class="dashboard-list">
                        {% for decision in latest_decisions %}
                            <a class="dashboard-list-item" href="{{ path('project_back_manage', {id: decision.project.id}) }}">
                                <div>
                                    <strong>{{ decision.project.title }}</strong>
                                    <p>{{ decision.description ?: 'Sans justification detaillee.' }}</p>
                                </div>
                                <div class="dashboard-list-meta">
                                    <span class="pm-status pm-status-{{ decision.project.status|lower }}">{{ decision.getDecisionTitleLabel() }}</span>
                                    <span>{{ decision.decisionDate|date('d/m/Y') }}</span>
                                </div>
                            </a>
                        {% else %}
                            <p class="dashboard-empty">Aucune decision enregistree.</p>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/back-dashboard.js') }}"></script>
{% endblock %}
