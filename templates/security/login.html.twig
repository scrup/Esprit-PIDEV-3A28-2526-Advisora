{% extends 'base.html.twig' %}

{% block title %}Advisora | Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% block body %}
<section class="pm-login-shell">
    <div class="pm-login-card">
        <span class="pm-badge">Authentification</span>
        <h1>Connexion au back office</h1>

        {% for message in app.flashes('success') %}
            <div class="flash-message flash-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="flash-message flash-error">{{ message }}</div>
        {% endfor %}

        {% if form_error %}
            <div class="flash-message flash-error">{{ form_error }}</div>
        {% elseif error and not field_errors.email and not field_errors.password %}
            <div class="flash-message flash-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" class="pm-login-form" novalidate>
            <div class="pm-field {{ field_errors.email ? 'pm-field-has-error' : '' }}">
                <label for="username">Email</label>
                <input type="email" id="username" name="_username" value="{{ last_username }}" autocomplete="username" required class="{{ field_errors.email ? 'pm-input pm-input-invalid' : 'pm-input' }}">
                <div class="pm-field-errors">{{ field_errors.email ?: '' }}</div>
            </div>

            <div class="pm-field {{ field_errors.password ? 'pm-field-has-error' : '' }}">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="_password" autocomplete="current-password" required class="{{ field_errors.password ? 'pm-input pm-input-invalid' : 'pm-input' }}">
                <div class="pm-field-errors">{{ field_errors.password ?: '' }}</div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button id="loginBtn" class="pm-btn pm-btn-primary pm-btn-block" type="submit">Se connecter</button>

            <div class="pm-login-separator">
                <span>ou</span>
            </div>

            <a class="pm-btn pm-btn-google pm-btn-block" href="{{ path('connect_google_start') }}">
                <img src="{{ asset('assets/images/google.png') }}" alt="" width="18" height="18">
                <span>Continuer avec Google</span>
            </a>

            <div style="margin-top: 12px; text-align: center;">
                <a href="{{ path('app_forgot_password') }}">Mot de passe oubliÃ© ?</a>
            </div>
            <div style="text-align: center;">
                <a href="{{ path('app_register') }}">Creer un compte</a>
            </div>
        </form>
    </div>
</section>
{% endblock %}
