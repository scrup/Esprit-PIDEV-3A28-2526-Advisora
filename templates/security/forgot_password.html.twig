{% extends 'base.html.twig' %}

{% block title %}Advisora | Mot de passe oublié{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
    <link rel="stylesheet" href="{{ asset('css/security-auth.css') }}?v=20260415">
{% endblock %}

{% block body %}
<section class="pm-login-shell auth-shell">
    <div class="pm-login-card auth-card">
        <span class="pm-badge">Réinitialisation</span>
        <h1>Mot de passe oublié</h1>
        <p class="auth-subtitle">Entrez votre email pour recevoir un code de réinitialisation.</p>

        {% for message in app.flashes('success') %}
            <div class="flash-message flash-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="flash-message flash-error">{{ message }}</div>
        {% endfor %}

        <form method="post" class="pm-login-form auth-form" novalidate>
            <label for="email">Email</label>
            <input type="text" id="email" name="email" value="{{ app.request.request.get('email') }}">

            <button
                class="pm-btn pm-btn-primary pm-btn-block"
                type="submit"
                id="sendCodeBtn"
                data-cooldown-end="{{ cooldownEndsAt|default(0) }}"
            >
                Envoyer le code
            </button>

            <div id="cooldownText" class="auth-cooldown-text"></div>

            <a class="auth-back-link" href="{{ path('app_login') }}">Retour à la connexion</a>
        </form>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const btn = document.getElementById('sendCodeBtn');
    const text = document.getElementById('cooldownText');

    if (!btn || !text) return;

    const cooldownEnd = parseInt(btn.dataset.cooldownEnd || '0', 10);

    function updateCooldown() {
        const now = Math.floor(Date.now() / 1000);
        const remaining = cooldownEnd - now;

        if (remaining > 0) {
            btn.disabled = true;
            btn.classList.add('is-disabled');
            btn.textContent = 'Code envoyé';
            text.textContent = 'Vous pourrez redemander un code dans ' + remaining + 's';
        } else {
            btn.disabled = false;
            btn.classList.remove('is-disabled');
            btn.textContent = 'Envoyer le code';
            text.textContent = '';
        }
    }

    updateCooldown();

    if (cooldownEnd > Math.floor(Date.now() / 1000)) {
        setInterval(updateCooldown, 1000);
    }
});
</script>
{% endblock %}