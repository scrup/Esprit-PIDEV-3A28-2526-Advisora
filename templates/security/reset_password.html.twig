{% extends 'base.html.twig' %}

{% block title %}Advisora | Réinitialiser le mot de passe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
    <link rel="stylesheet" href="{{ asset('css/security-auth.css') }}?v=20260415">
{% endblock %}

{% block body %}
<section class="pm-login-shell auth-shell">
    <div class="pm-login-card auth-card">
        <span class="pm-badge">Réinitialisation</span>
        <h1>Nouveau mot de passe</h1>
        <p class="auth-subtitle">Vérifiez d’abord le code reçu par email.</p>

        <div class="auth-email-chip">
            Code envoyé à : <strong>{{ resetEmail }}</strong>
        </div>

        {% for message in app.flashes('success') %}
            <div class="flash-message flash-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="flash-message flash-error">{{ message }}</div>
        {% endfor %}

        {% if not codeVerified %}
            <form method="post" class="pm-login-form auth-form" novalidate>
                <input type="hidden" name="action" value="verify_code">

                <label for="code">Code reçu par email</label>
                <input type="text" id="code" name="code" value="{{ app.request.request.get('code') }}">

                <button class="pm-btn pm-btn-primary pm-btn-block" type="submit">
                    Vérifier le code
                </button>

                <a class="auth-back-link" href="{{ path('app_forgot_password') }}">Renvoyer un code</a>
            </form>
        {% else %}
            <div class="auth-verified-chip">Code vérifié avec succès.</div>

            <form method="post" class="pm-login-form auth-form" novalidate>
                <input type="hidden" name="action" value="change_password">

                <label for="password">Nouveau mot de passe</label>
                <input type="password" id="password" name="password">

                <label for="confirm_password">Confirmer le mot de passe</label>
                <input type="password" id="confirm_password" name="confirm_password">

                <button class="pm-btn pm-btn-primary pm-btn-block" type="submit">
                    Réinitialiser
                </button>
            </form>
        {% endif %}

        <a class="auth-back-link" href="{{ path('app_login') }}">Retour à la connexion</a>
    </div>
</section>
{% endblock %}