<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Advisora Back Office{% endblock %}</title>
    
    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="{{ asset('css/back-base.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- BACK OFFICE HEADER -->
<header class="back-header">
    <div class="logo">
        <img src="{{ asset('assets/logo.png') }}" alt="Advisora Logo" class="logo-img" onerror="this.style.display='none'">
        Advisora</span>
    </div>
    <nav class="back-nav">
        <a href="#" class="active"><i class="fas fa-home"></i> Accueil</a>
        <a href="#"><i class="fas fa-folder-open"></i> Mes Projets</a>
        <a href="#"><i class="fas fa-chart-line"></i> Stratégies</a>
        <a href="#"><i class="fas fa-book"></i> Ressources</a>
        <a href="#"><i class="fas fa-calendar-alt"></i> Événements</a>
        <a href="#"><i class="fas fa-chart-simple"></i> Investissements</a>
        <a href="#"><i class="fas fa-user"></i> Profil</a>
    </nav>
    <div class="header-actions">
        <div class="user-info">
            <i class="fas fa-user-circle"></i>
            <span>Thomas</span>
        </div>
        <button class="btn-logout" id="logoutBtn"><i class="fas fa-sign-out-alt"></i></button>
    </div>
</header>

<main>
    {% block body %}{% endblock %}
</main>


{% block javascripts %}{% endblock %}
</body>
</html>