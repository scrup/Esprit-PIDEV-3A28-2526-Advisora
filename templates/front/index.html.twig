{% extends 'base.html.twig' %}

{% block title %}{{ 'home.meta.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
    <section class="hero">
        <div class="hero-text">
            <span class="badge"><i class="fas fa-rocket"></i> {{ 'home.hero.badge'|trans }}</span>
            <h1>{{ 'home.hero.title'|trans }}</h1>
            <p>{{ 'home.hero.description'|trans }}</p>
            <button class="btn btn-primary" id="heroCta">
                {{ 'home.hero.cta'|trans }} <i class="fas fa-arrow-right"></i>
            </button>
            <div class="hero-stats">
                <div class="stat"><span class="stat-number">2,4 Mds DT</span><span>{{ 'home.hero.stats.assets'|trans }}</span></div>
                <div class="stat"><span class="stat-number">98%</span><span>{{ 'home.hero.stats.clients'|trans }}</span></div>
                <div class="stat"><span class="stat-number">15+</span><span>{{ 'home.hero.stats.awards'|trans }}</span></div>
            </div>
        </div>
        <div class="hero-image">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&auto=format" alt="{{ 'home.hero.image_alt'|trans }}">
            <div class="floating-card">
                <i class="fas fa-chart-line"></i> <span>{{ 'home.hero.floating_card'|trans }}</span>
            </div>
        </div>
    </section>

    <section id="about" class="about-section">
        <div class="about-container">
            <div class="about-text">
                <h2 class="section-title" style="text-align: left;">{{ 'home.about.title'|trans }}</h2>
                <p class="about-intro">{{ 'home.about.intro'|trans }}</p>
                <p>{{ 'home.about.description'|trans }}</p>
                <div class="about-highlight">
                    <i class="fas fa-handshake"></i>
                    <div>
                        <strong>{{ 'home.about.commitment_title'|trans }}</strong>
                        <p>{{ 'home.about.commitment_text'|trans }}</p>
                    </div>
                </div>
                <div class="about-stats">
                    <div class="about-stat">
                        <span class="about-number">12+</span>
                        <span>{{ 'home.about.stats.experience'|trans }}</span>
                    </div>
                    <div class="about-stat">
                        <span class="about-number">350+</span>
                        <span>{{ 'home.about.stats.companies'|trans }}</span>
                    </div>
                    <div class="about-stat">
                        <span class="about-number">4.9/5</span>
                        <span>{{ 'home.about.stats.rating'|trans }}</span>
                    </div>
                </div>
            </div>
            <div class="about-image">
                <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&auto=format" alt="{{ 'home.about.image_alt'|trans }}">
                <div class="about-badge">
                    <i class="fas fa-chart-line"></i> {{ 'home.about.badge'|trans }}
                </div>
            </div>
        </div>
    </section>

    <section id="solutions" class="solutions-section">
        <h2 class="section-title">{{ 'home.solutions.title_before'|trans }} <span style="color:#C37D5D;">{{ 'home.solutions.title_highlight'|trans }}</span></h2>
        <p class="section-sub">{{ 'home.solutions.subtitle'|trans }}</p>
        <div class="feature-grid">
            <div class="card">
                <div class="card-icon"><i class="fas fa-chart-pie"></i></div>
                <h3>{{ 'home.solutions.cards.analytics.title'|trans }}</h3>
                <p>{{ 'home.solutions.cards.analytics.text'|trans }}</p>
                <span class="card-link">{{ 'home.common.learn_more'|trans }}</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-brain"></i></div>
                <h3>{{ 'home.solutions.cards.ai.title'|trans }}</h3>
                <p>{{ 'home.solutions.cards.ai.text'|trans }}</p>
                <span class="card-link">{{ 'home.common.learn_more'|trans }}</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-shield-alt"></i></div>
                <h3>{{ 'home.solutions.cards.risk.title'|trans }}</h3>
                <p>{{ 'home.solutions.cards.risk.text'|trans }}</p>
                <span class="card-link">{{ 'home.common.learn_more'|trans }}</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-charging-station"></i></div>
                <h3>{{ 'home.solutions.cards.wealth.title'|trans }}</h3>
                <p>{{ 'home.solutions.cards.wealth.text'|trans }}</p>
                <span class="card-link">{{ 'home.common.learn_more'|trans }}</span>
            </div>
        </div>
    </section>

    <section id="whyus" class="whyus-section">
        <h2 class="section-title">{{ 'home.whyus.title_before'|trans }} <span style="color:#C37D5D;">{{ 'home.whyus.title_highlight'|trans }}</span></h2>
        <p class="section-sub">{{ 'home.whyus.subtitle'|trans }}</p>

        <div class="whyus-grid">
            <div class="whyus-card">
                <i class="fas fa-chart-line"></i>
                <h3>{{ 'home.whyus.cards.performance.title'|trans }}</h3>
                <p>{{ 'home.whyus.cards.performance.text'|trans|raw }}</p>
            </div>
            <div class="whyus-card">
                <i class="fas fa-clock"></i>
                <h3>{{ 'home.whyus.cards.time.title'|trans }}</h3>
                <p>{{ 'home.whyus.cards.time.text'|trans|raw }}</p>
            </div>
            <div class="whyus-card">
                <i class="fas fa-shield-alt"></i>
                <h3>{{ 'home.whyus.cards.security.title'|trans }}</h3>
                <p>{{ 'home.whyus.cards.security.text'|trans }}</p>
            </div>
        </div>

        <div class="chart-container">
            <div class="chart-card">
                <h3><i class="fas fa-chart-line"></i> {{ 'home.whyus.charts.roi.title'|trans }}</h3>
                <canvas id="roiChart" width="400" height="250"></canvas>
                <p class="chart-note">{{ 'home.whyus.charts.roi.note'|trans }}</p>
            </div>
            <div class="chart-card">
                <h3><i class="fas fa-chart-bar"></i> {{ 'home.whyus.charts.risk.title'|trans }}</h3>
                <canvas id="riskChart" width="400" height="250"></canvas>
                <p class="chart-note">{{ 'home.whyus.charts.risk.note'|trans }}</p>
            </div>
        </div>

        <div class="prediction-banner">
            <div class="prediction-item">
                <span class="prediction-label">{{ 'home.whyus.predictions.roi'|trans }}</span>
                <span class="prediction-value">+38%</span>
            </div>
            <div class="prediction-item">
                <span class="prediction-label">{{ 'home.whyus.predictions.success'|trans }}</span>
                <span class="prediction-value">92%</span>
            </div>
            <div class="prediction-item">
                <span class="prediction-label">{{ 'home.whyus.predictions.recommend'|trans }}</span>
                <span class="prediction-value">96%</span>
            </div>
        </div>
    </section>

    <section id="reviews" class="testimonials">
        <h2 class="section-title">{{ 'home.reviews.title_before'|trans }} <span style="color:#C37D5D;">{{ 'home.reviews.title_highlight'|trans }}</span></h2>
        <p class="section-sub">{{ 'home.reviews.subtitle'|trans }}</p>
        <div class="testimonial-grid">
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p>{{ 'home.reviews.cards.elena.quote'|trans }}</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="client">
                    <div><strong>Elena Marchetti</strong><br>{{ 'home.reviews.cards.elena.role'|trans }}</div>
                </div>
            </div>
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p>{{ 'home.reviews.cards.james.quote'|trans }}</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="client">
                    <div><strong>James O'Connor</strong><br>{{ 'home.reviews.cards.james.role'|trans }}</div>
                </div>
            </div>
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i></div>
                <p>{{ 'home.reviews.cards.priya.quote'|trans }}</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/women/45.jpg" alt="client">
                    <div><strong>Priya Kapoor</strong><br>{{ 'home.reviews.cards.priya.role'|trans }}</div>
                </div>
            </div>
        </div>
    </section>

    <div class="cta-banner">
        <div class="cta-text">
            <h2>{{ 'home.cta.title'|trans }}</h2>
            <p>{{ 'home.cta.text'|trans }}</p>
        </div>
        <button class="btn btn-primary" id="ctaBannerBtn">{{ 'home.cta.button'|trans }}</button>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="{{ asset('js/main.js') }}"></script>
{% endblock %}