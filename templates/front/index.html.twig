{% extends 'base.html.twig' %}

{% block title %}Advisora | Conseil financier intelligent{% endblock %}

{# Add Chart.js for charts #}
{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block body %}
    <!-- HERO SECTION -->
    <section class="hero">
        <div class="hero-text">
            <span class="badge"><i class="fas fa-rocket"></i> Conseil financier nouvelle génération</span>
            <h1>Des décisions éclairées pour une croissance durable</h1>
            <p>Alliez la puissance de l'IA à l'expertise humaine pour transformer vos données en opportunités concrètes.</p>
            <button class="btn btn-primary" id="heroCta">Découvrir nos solutions <i class="fas fa-arrow-right"></i></button>
            <div class="hero-stats">
                <div class="stat"><span class="stat-number">2,4 Mds DT</span><span>Actifs sous conseil</span></div>
                <div class="stat"><span class="stat-number">98%</span><span>Clients satisfaits</span></div>
                <div class="stat"><span class="stat-number">15+</span><span>Prix d'excellence</span></div>
            </div>
        </div>
        <div class="hero-image">
            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&auto=format" alt="Analyse financière">
            <div class="floating-card">
                <i class="fas fa-chart-line"></i> <span>Performance +32% en moyenne</span>
            </div>
        </div>
    </section>

    <!-- ABOUT SECTION -->
    <section id="about" class="about-section">
        <div class="about-container">
            <div class="about-text">
                <h2 class="section-title" style="text-align: left;">Qui sommes-nous ?</h2>
                <p class="about-intro">Nous sommes là pour vous guider et réaliser vos objectifs financiers avec excellence et intégrité.</p>
                <p>Fondé en 2012, Advisora est un cabinet de conseil financier nouvelle génération qui allie technologie de pointe et expertise humaine. Notre mission : démocratiser l'accès à des conseils financiers de qualité supérieure, grâce à l'intelligence artificielle et à l'analyse prédictive.</p>
                <div class="about-highlight">
                    <i class="fas fa-handshake"></i>
                    <div>
                        <strong>Notre engagement</strong>
                        <p>Accompagner chaque client avec transparence, innovation et résultats mesurables.</p>
                    </div>
                </div>
                <div class="about-stats">
                    <div class="about-stat">
                        <span class="about-number">12+</span>
                        <span>années d'expertise</span>
                    </div>
                    <div class="about-stat">
                        <span class="about-number">350+</span>
                        <span>entreprises accompagnées</span>
                    </div>
                    <div class="about-stat">
                        <span class="about-number">4.9/5</span>
                        <span>note moyenne clients</span>
                    </div>
                </div>
            </div>
            <div class="about-image">
                <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&auto=format" alt="Notre équipe">
                <div class="about-badge">
                    <i class="fas fa-chart-line"></i> +42% ROI moyen client
                </div>
            </div>
        </div>
    </section>

    <!-- SOLUTIONS SECTION -->
    <section id="solutions" class="solutions-section">
        <h2 class="section-title">Solutions intelligentes pour la <span style="color:#C37D5D;">croissance</span></h2>
        <p class="section-sub">De la modélisation prédictive à la gestion des risques — nous vous aidons à réussir.</p>
        <div class="feature-grid">
            <div class="card">
                <div class="card-icon"><i class="fas fa-chart-pie"></i></div>
                <h3>Analyses intelligentes</h3>
                <p>Tableaux de bord interactifs avec suivi des KPI en temps réel et signaux de marché.</p>
                <span class="card-link">En savoir plus →</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-brain"></i></div>
                <h3>Moteur de stratégie IA</h3>
                <p>Stratégies d'investissement sur mesure utilisant l'apprentissage automatique.</p>
                <span class="card-link">En savoir plus →</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-shield-alt"></i></div>
                <h3>Risque & conformité</h3>
                <p>Évaluation proactive des risques + outils de conformité réglementaire automatisés.</p>
                <span class="card-link">En savoir plus →</span>
            </div>
            <div class="card">
                <div class="card-icon"><i class="fas fa-charging-station"></i></div>
                <h3>Accélération de patrimoine</h3>
                <p>Optimisation de portefeuille pour haute valeur nette avec modèles fiscaux efficaces.</p>
                <span class="card-link">En savoir plus →</span>
            </div>
        </div>
    </section>

    <!-- WHY CHOOSE US SECTION -->
    <section id="whyus" class="whyus-section">
        <h2 class="section-title">Pourquoi <span style="color:#C37D5D;">nous choisir ?</span></h2>
        <p class="section-sub">Découvrez l'impact mesurable de notre accompagnement sur votre performance financière.</p>
        
        <div class="whyus-grid">
            <div class="whyus-card">
                <i class="fas fa-chart-line"></i>
                <h3>Performance prouvée</h3>
                <p>Nos clients constatent en moyenne une amélioration de <strong>+42%</strong> de leur rentabilité dans les 12 premiers mois.</p>
            </div>
            <div class="whyus-card">
                <i class="fas fa-clock"></i>
                <h3>Gain de temps précieux</h3>
                <p>Automatisation des analyses qui réduit de <strong>70%</strong> le temps consacré aux rapports financiers.</p>
            </div>
            <div class="whyus-card">
                <i class="fas fa-shield-alt"></i>
                <h3>Sécurité maximale</h3>
                <p>Protection des données de niveau bancaire et conformité RGPD certifiée.</p>
            </div>
        </div>

        <!-- Interactive Charts -->
        <div class="chart-container">
            <div class="chart-card">
                <h3><i class="fas fa-chart-line"></i> Croissance projetée du ROI</h3>
                <canvas id="roiChart" width="400" height="250"></canvas>
                <p class="chart-note">Avec Advisora vs stratégie traditionnelle - Projection sur 5 ans</p>
            </div>
            <div class="chart-card">
                <h3><i class="fas fa-chart-bar"></i> Réduction des risques</h3>
                <canvas id="riskChart" width="400" height="250"></canvas>
                <p class="chart-note">Diminution de la volatilité du portefeuille après accompagnement</p>
            </div>
        </div>

        <div class="prediction-banner">
            <div class="prediction-item">
                <span class="prediction-label">Retour sur investissement moyen</span>
                <span class="prediction-value">+38%</span>
            </div>
            <div class="prediction-item">
                <span class="prediction-label">Taux de réussite stratégique</span>
                <span class="prediction-value">92%</span>
            </div>
            <div class="prediction-item">
                <span class="prediction-label">Clients qui recommandent</span>
                <span class="prediction-value">96%</span>
            </div>
        </div>
    </section>

    <!-- REVIEWS SECTION -->
    <section id="reviews" class="testimonials">
        <h2 class="section-title">Ce que nos <span style="color:#C37D5D;">clients disent</span></h2>
        <p class="section-sub">Des retours authentiques de dirigeants qui nous ont fait confiance.</p>
        <div class="testimonial-grid">
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p>“Advisora a transformé notre allocation d'actifs. Les alertes en temps réel et les insights IA nous ont donné un avantage concurrentiel indéniable.”</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/women/68.jpg" alt="client">
                    <div><strong>Elena Marchetti</strong><br>CFO, FinCore</div>
                </div>
            </div>
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i></div>
                <p>“Des outils stratégiques exceptionnels. Notre ROI a augmenté de 27% en 6 mois grâce à leur tableau de bord et à leurs recommandations personnalisées.”</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/men/32.jpg" alt="client">
                    <div><strong>James O'Connor</strong><br>Directeur stratégie</div>
                </div>
            </div>
            <div class="testi-card">
                <div class="stars"><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i></div>
                <p>“Moderne, élégant et incroyablement perspicace. L'analytique prédictive nous a évité des pertes majeures et optimisé nos investissements.”</p>
                <div class="client">
                    <img src="https://randomuser.me/api/portraits/women/45.jpg" alt="client">
                    <div><strong>Priya Kapoor</strong><br>Directrice d'investissement</div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA BANNER -->
    <div class="cta-banner">
        <div class="cta-text">
            <h2>Prêt à transformer votre approche financière ?</h2>
            <p>Rejoignez les entreprises qui font confiance à Advisora pour une croissance durable et performante.</p>
        </div>
        <button class="btn btn-primary" id="ctaBannerBtn">Planifier une démo →</button>
    </div>
{% endblock %}

{# Add JavaScript for charts and interactions #}
{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="{{ asset('js/main.js') }}"></script>
{% endblock %}