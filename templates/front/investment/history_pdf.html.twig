<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Historique des Investissements</title>
    <style>
        body { font-family: Arial, sans-serif; color: #333; margin: 20px; }
        .header { text-align: center; margin-bottom: 40px; border-bottom: 2px solid #C37D5D; padding-bottom: 10px; }
        .header h1 { color: #C37D5D; margin: 0; }
        .card { border: 1px solid #ddd; margin-bottom: 20px; padding: 15px; border-radius: 5px; }
        .card-header { font-size: 1.1em; font-weight: bold; margin-bottom: 10px; background-color: #f9f9f9; padding: 10px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.8em; }
        th, td { border-bottom: 1px solid #eee; padding: 8px; text-align: left; }
        th { background-color: #fdfdfd; }
        .right { text-align: right; }
        .success { color: #2ecc71; font-weight: bold; }
        .summary { font-size: 0.9em; margin-bottom: 10px; }
        .footer { text-align: center; font-size: 0.8em; margin-top: 50px; color: #777; }
    </style>
</head>
<body>
    <div class="header">
        <h1>Advisora - Historique des Investissements</h1>
        <p>Reçu généré le {{ 'now'|date('d/m/Y à H:i') }}</p>
    </div>

    {% for investment in investments %}
        {% set active_trans = investment.getTotalActiveTransactionsAmount() %}
        <div class="card">
            <div class="card-header">
                Projet : {{ investment.project ? investment.project.title : 'N/A' }} 
            </div>
            <div class="summary">
                <table style="border:none; margin:0; padding:0;">
                    <tr>
                        <td style="border:none;"><strong>Budget Alloué :</strong> {{ investment.BudMaxInv|number_format(2, '.', ' ') }} {{ investment.CurrencyInv }}</td>
                        <td style="border:none;" class="right"><strong>Total Transféré :</strong> <span class="success">{{ active_trans|number_format(2, '.', ' ') }} {{ investment.CurrencyInv }}</span></td>
                    </tr>
                </table>
            </div>

            {% if investment.transactions is not empty %}
                <table>
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Statut</th>
                            <th class="right">Montant</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for tx in investment.transactions %}
                            <tr>
                                <td>{{ tx.DateTransac ? tx.DateTransac|date('d/m/Y') : '-' }}</td>
                                <td>{{ tx.statusLabel }}</td>
                                <td class="right">{{ tx.MontantTransac|number_format(2, '.', ' ') }} {{ investment.CurrencyInv }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p style="font-size: 0.8em; color: #888;">Aucune transaction enregistrée.</p>
            {% endif %}
        </div>
    {% else %}
        <p>Aucun investissement trouvé.</p>
    {% endfor %}

    <div class="footer">
        Advisora Conseil et Suivi Stratégique - Document Officiel
    </div>
</body>
</html>