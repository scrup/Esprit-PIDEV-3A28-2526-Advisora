{% if prediction %}
    <section class="pm-card pm-investment-analysis-card">
        <details class="pm-analysis-disclosure">
            <summary class="pm-analysis-trigger">
                <span class="pm-btn pm-btn-primary">
                    <i class="fas fa-chart-line"></i>
                    <span>{{ 'investment.prediction.view'|trans }}</span>
                </span>
            </summary>

            <div class="pm-analysis-body">
                <div class="pm-analysis-head">
                    <div>
                        <span class="pm-badge">{{ 'investment.prediction.badge'|trans }}</span>
                        <h2>{{ 'investment.prediction.business_read'|trans }}</h2>
                        <p>{{ prediction.sectorOutlook }}</p>
                    </div>
                    <div class="pm-analysis-score-panel">
                        <span class="pm-prediction-badge pm-prediction-badge-{{ prediction.recommendationBadgeClass }}">{{ prediction.recommendationLabel }}</span>
                        <strong>{{ prediction.scorePercent }}/100</strong>
                        <span>{{ 'investment.prediction.global_score'|trans }}</span>
                    </div>
                </div>

                <div class="pm-analysis-badge-row">
                    <span class="pm-analysis-chip">{{ prediction.sectorLabel }}</span>
                    <span class="pm-analysis-chip">{{ 'investment.prediction.project_chip'|trans }}: {{ prediction.projectType }}</span>
                    <span class="pm-analysis-chip">{{ 'investment.prediction.country'|trans }}</span>
                    <span class="pm-analysis-chip">{{ 'investment.prediction.history_count'|trans }}: {{ prediction.similarProjectsCount }}</span>
                </div>

                <div class="pm-analysis-metric-grid">
                    <article class="pm-analysis-metric">
                        <span class="pm-analysis-metric-label">{{ 'investment.prediction.recommendation'|trans }}</span>
                        <strong class="pm-analysis-metric-value">{{ prediction.recommendationLabel }}</strong>
                        <span class="pm-analysis-metric-note">{{ 'investment.prediction.simple_read'|trans }}</span>
                    </article>
                    <article class="pm-analysis-metric">
                        <span class="pm-analysis-metric-label">{{ 'investment.prediction.adjusted_roi'|trans }}</span>
                        <strong class="pm-analysis-metric-value {{ prediction.macroAnalysis.adjustedRoi >= 0 ? 'is-positive' : 'is-negative' }}">
                            {{ prediction.macroAnalysis.adjustedRoi|number_format(2, '.', ' ') }}%
                        </strong>
                        <span class="pm-analysis-metric-note">{{ 'investment.prediction.raw_base'|trans }} {{ prediction.macroAnalysis.grossRoi|number_format(2, '.', ' ') }}%</span>
                    </article>
                    <article class="pm-analysis-metric">
                        <span class="pm-analysis-metric-label">{{ 'investment.prediction.macro_risk'|trans }}</span>
                        <strong class="pm-analysis-metric-value">{{ prediction.macroAnalysis.riskLevelLabel }}</strong>
                        <span class="pm-analysis-metric-note">{{ 'investment.prediction.score'|trans }} {{ prediction.macroAnalysis.score|number_format(1, '.', ' ') }}/100</span>
                    </article>
                    <article class="pm-analysis-metric">
                        <span class="pm-analysis-metric-label">{{ 'investment.prediction.sector_rate'|trans }}</span>
                        <strong class="pm-analysis-metric-value">{{ prediction.acceptanceRatePercent }}%</strong>
                        <span class="pm-analysis-metric-note">{{ 'investment.prediction.similar_projects_history'|trans }}</span>
                    </article>
                </div>

                <div class="pm-analysis-highlight-list">
                    {% for highlight in prediction.highlights %}
                        <article class="pm-analysis-highlight">
                            <i class="fas fa-circle-check"></i>
                            <span>{{ highlight }}</span>
                        </article>
                    {% endfor %}
                </div>

                <details class="pm-analysis-details-disclosure">
                    <summary class="pm-analysis-trigger-secondary">
                        <span class="pm-btn pm-btn-secondary">
                            <i class="fas fa-magnifying-glass-chart"></i>
                            <span>{{ 'investment.prediction.more_details'|trans }}</span>
                        </span>
                    </summary>

                    <div class="pm-analysis-detail-grid">
                        {% for block in prediction.reasonBlocks %}
                            <article class="pm-analysis-detail-card pm-analysis-detail-card-{{ block.variant }}">
                                <div class="pm-analysis-detail-head">
                                    <span>{{ block.title }}</span>
                                    <strong>{{ block.badge }}</strong>
                                </div>
                                <p>{{ block.description }}</p>
                            </article>
                        {% endfor %}
                    </div>

                    <div class="pm-analysis-macro-board">
                        <article class="pm-analysis-mini-stat">
                            <span>{{ 'investment.prediction.inflation'|trans }}</span>
                            <strong>{{ prediction.macroAnalysis.data.inflation|number_format(2, '.', ' ') }}%</strong>
                            <small>{{ prediction.macroAnalysis.data.inflationYear }}</small>
                        </article>
                        <article class="pm-analysis-mini-stat">
                            <span>{{ 'investment.prediction.real_gdp'|trans }}</span>
                            <strong>{{ prediction.macroAnalysis.data.gdpGrowth|number_format(2, '.', ' ') }}%</strong>
                            <small>{{ prediction.macroAnalysis.data.gdpGrowthYear }}</small>
                        </article>
                        <article class="pm-analysis-mini-stat">
                            <span>{{ 'investment.prediction.lending_rate'|trans }}</span>
                            <strong>{{ prediction.macroAnalysis.data.lendingRate|number_format(2, '.', ' ') }}%</strong>
                            <small>
                                {{ prediction.macroAnalysis.data.lendingEstimated ? ('investment.prediction.bct_prefix'|trans) : '' }}{{ prediction.macroAnalysis.data.lendingRateYear }}
                            </small>
                        </article>
                        <article class="pm-analysis-mini-stat">
                            <span>{{ 'investment.prediction.risk_premium'|trans }}</span>
                            <strong>{{ prediction.macroAnalysis.riskPremium|number_format(2, '.', ' ') }}%</strong>
                            <small>{{ prediction.macroAnalysis.riskLevelLabel }}</small>
                        </article>
                    </div>

                    <div class="pm-analysis-metric-grid pm-analysis-metric-grid-secondary">
                        <article class="pm-analysis-metric">
                            <span class="pm-analysis-metric-label">{{ 'investment.prediction.macro_readiness'|trans }}</span>
                            <strong class="pm-analysis-metric-value">{{ prediction.macroReadinessScore }}%</strong>
                            <span class="pm-analysis-metric-note">{{ 'investment.prediction.macro_impact_note'|trans }}</span>
                        </article>
                        <article class="pm-analysis-metric">
                            <span class="pm-analysis-metric-label">{{ 'investment.prediction.budget_fit'|trans }}</span>
                            <strong class="pm-analysis-metric-value">{{ prediction.budgetFitScore }}%</strong>
                            <span class="pm-analysis-metric-note">
                                {% if prediction.medianAcceptedBudget is not null %}
                                    {{ 'investment.prediction.accepted_median'|trans }}: {{ prediction.medianAcceptedBudget|number_format(2, '.', ' ') }} TND
                                {% else %}
                                    {{ 'investment.prediction.global_reference'|trans }}
                                {% endif %}
                            </span>
                        </article>
                        <article class="pm-analysis-metric">
                            <span class="pm-analysis-metric-label">{{ 'investment.prediction.project_readiness'|trans }}</span>
                            <strong class="pm-analysis-metric-value">{{ prediction.projectReadinessScore }}%</strong>
                            <span class="pm-analysis-metric-note">{{ 'investment.prediction.project_quality_note'|trans }}</span>
                        </article>
                    </div>

                    {% if prediction.warnings is not empty %}
                        <div class="pm-analysis-warning-list">
                            {% for warning in prediction.warnings %}
                                <div class="pm-analysis-warning">
                                    <i class="fas fa-triangle-exclamation"></i>
                                    <span>{{ warning }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}
                </details>
            </div>
        </details>
    </section>
{% elseif prediction_error is defined and prediction_error %}
    <section class="pm-card pm-investment-analysis-card">
        <div class="pm-analysis-warning">
            <i class="fas fa-triangle-exclamation"></i>
            <span>{{ prediction_error }}</span>
        </div>
    </section>
{% endif %}
