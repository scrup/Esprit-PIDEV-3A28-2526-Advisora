{% extends 'base.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ page_badge }}</span>
                <h1>{{ page_title }}</h1>
                <p>{{ page_message }}</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ back_route == 'investment_manage' and investment.id ? path(back_route, {id: investment.id}) : path(back_route) }}">Retour</a>
        </div>

        {% include 'front/investment/_module_nav.html.twig' %}

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Projet preselectionne :</strong> {{ project ? project.title : 'Aucun pour le moment' }}<br>
                <strong>ID projet :</strong> {{ project ? project.id : 'A selectionner' }}<br>
                <strong>Budget projet :</strong> {{ project and project.legacyBudget is not null ? project.legacyBudget|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}<br>
                <strong>Projets disponibles :</strong> {{ projects_count|default(0) }}
            </div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', class: 'pm-validated-form', 'data-validation-form': 'investment'}}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {% if form.project is defined %}
                        {{ forms.field(form.project) }}
                    {% endif %}
                    {{ forms.field(form.commentaireInv) }}
                    {{ forms.field(form.durationEstimateLabel) }}
                    {{ forms.field(form.bud_minInv) }}
                    {{ forms.field(form.bud_maxInv) }}
                    {{ forms.field(form.CurrencyInv) }}
                </div>
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/investment-form-validation.js') }}"></script>
{% endblock %}
