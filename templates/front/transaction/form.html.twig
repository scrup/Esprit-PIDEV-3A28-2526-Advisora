{% extends 'base.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">{{ page_badge }}</span>
                <h1>{{ page_title }}</h1>
                <p>{{ page_message }}</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ back_route == 'investment_manage' and investment and investment.id ? path(back_route, {id: investment.id}) : path(back_route) }}">Retour</a>
        </div>

        {% include 'front/investment/_module_nav.html.twig' %}

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Investissement :</strong> #{{ investment ? investment.id : 'N/A' }}<br>
                <strong>Projet :</strong> {{ investment and investment.project ? investment.project.title : 'Projet indisponible' }}<br>
                <strong>Fourchette autorisee :</strong> {{ investment ? investment.budgetRangeLabel : 'N/A' }}
            </div>
            {{ form_start(form, {attr: {
                novalidate: 'novalidate',
                class: 'pm-validated-form',
                'data-validation-form': 'transaction',
                'data-investment-min': investment ? investment.budMinInv : '',
                'data-investment-max': investment ? investment.budMaxInv : '',
                'data-investment-currency': investment and investment.currencyInv ? investment.currencyInv : 'TND'
            }}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {{ forms.field(form.DateTransac) }}
                    {{ forms.field(form.MontantTransac) }}
                    {{ forms.field(form.type) }}
                </div>
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/transaction-form-validation.js') }}"></script>
{% endblock %}
