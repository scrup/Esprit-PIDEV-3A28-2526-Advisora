{% extends 'base.html.twig' %}

{% block title %}{{ 'project.meta.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% block body %}
    <section class="pm-hero">
        <div>
            <span class="pm-badge">{{ 'project.hero.badge'|trans }}</span>
            <h1>{{ 'project.hero.title'|trans }}</h1>
            <p>
                {% if app.user and not can_see_all_projects %}
                    {{ 'project.hero.description_client'|trans }}
                {% else %}
                    {{ 'project.hero.description_all'|trans }}
                {% endif %}
            </p>
        </div>
        <div class="pm-actions">
            {% if app.user and can_manage_projects %}
                <a class="pm-btn pm-btn-primary" href="{{ path('project_new') }}">{{ 'project.hero.add'|trans }}</a>
            {% elseif not app.user %}
                <a class="pm-btn pm-btn-primary" href="{{ path('app_login') }}">{{ 'project.hero.login_manage'|trans }}</a>
            {% endif %}
        </div>
    </section>

    <section class="pm-hero">
        <form method="get" action="{{ path('project_index') }}" class="pm-form-card">
            <div class="pm-filter-grid">
                <div class="pm-field">
                    <label for="filter_q">{{ 'project.filters.search'|trans }}</label>
                    <input id="filter_q" type="search" name="q" placeholder="{{ 'project.filters.search_placeholder'|trans }}" value="{{ filters.q|default('') }}">
                </div>

                <div class="pm-field">
                    <label for="filter_status">{{ 'project.filters.status'|trans }}</label>
                    <select id="filter_status" name="status">
                        <option value="">{{ 'project.filters.all'|trans }}</option>
                        {% for status_value, status_label in status_choices %}
                            <option value="{{ status_value }}" {% if filters.status is defined and filters.status == status_value %}selected{% endif %}>{{ status_label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="pm-field">
                    <label for="filter_type">{{ 'project.filters.type'|trans }}</label>
                    <select id="filter_type" name="type">
                        <option value="">{{ 'project.filters.all'|trans }}</option>
                        {% for project_type in type_choices %}
                            <option value="{{ project_type }}" {% if filters.type is defined and filters.type == project_type %}selected{% endif %}>{{ project_type }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="pm-field">
                    <label for="filter_min_price">{{ 'project.filters.min_budget'|trans }}</label>
                    <input id="filter_min_price" type="number" step="0.01" name="min_price" placeholder="{{ 'project.filters.min'|trans }}" value="{{ filters.min_price|default('') }}">
                </div>

                <div class="pm-field">
                    <label for="filter_max_price">{{ 'project.filters.max_budget'|trans }}</label>
                    <input id="filter_max_price" type="number" step="0.01" name="max_price" placeholder="{{ 'project.filters.max'|trans }}" value="{{ filters.max_price|default('') }}">
                </div>
            </div>

            <div class="pm-filter-actions">
                <button class="pm-btn pm-btn-primary" type="submit">{{ 'project.filters.apply'|trans }}</button>
                <a class="pm-btn pm-btn-secondary" href="{{ path('project_index') }}">{{ 'project.filters.reset'|trans }}</a>
            </div>
        </form>
    </section>

    <section class="pm-grid">
        {% for project in projects %}
            <article class="pm-card">
                {% set estimate = project_acceptance_estimates[project.id]|default(null) %}
                <div class="pm-card-head">
                    <span class="pm-status pm-status-{{ project.status|lower }}">{{ project.getStatusLabel() }}</span>
                    <span class="pm-meta">{{ 'project.card.project_number'|trans }} #{{ project.id }}</span>
                </div>
                <h2>{{ project.title }}</h2>
                <p>{{ project.description ?: ('project.card.no_description'|trans) }}</p>
                <div class="pm-meta-list">
                    <span><i class="fas fa-layer-group"></i> {{ 'project.card.type'|trans }} : {{ project.legacyType ?: ('project.card.not_specified'|trans) }}</span>
                    <span><i class="fas fa-wallet"></i> {{ 'project.card.budget'|trans }} : {{ project.legacyBudget is not null ? project.legacyBudget|number_format(2, '.', ' ') ~ ' TND' : ('project.card.not_specified'|trans) }}</span>
                    <span><i class="fas fa-calendar-plus"></i> {{ 'project.card.creation'|trans }} : {{ project.startDate ? project.startDate|date('d/m/Y') : ('project.card.not_specified_female'|trans) }}</span>
                </div>
                <div class="pm-meta-list">
                    <span><i class="fas fa-sitemap"></i> {{ project.decisions|length }} {{ 'project.card.decisions'|trans }}</span>
                </div>
                {% if can_see_all_projects %}
                    <a href="{{ path('strategie_recommandation', {'id': project.id}) }}" class="pm-btn pm-btn-primary">
                        Generer une strategie recommandee
                    </a>
                {% endif %}

                {% if project.status == constant('App\\Entity\\Project::STATUS_PENDING') and estimate %}
                    {% include 'shared/project_acceptance_estimate.html.twig' with { estimate: estimate } only %}
                {% endif %}
              
                {% if project.strategies|length > 0 %}
                    <div class="pm-project-strategies pm-project-strategies-inline">
                        <div class="pm-section-head">
                            <div>
                                <span class="pm-badge">{{ 'project.strategies.badge'|trans }}</span>
                                <p class="pm-section-text">{{ 'project.strategies.text'|trans }}</p>
                            </div>
                            <span class="pm-history-count">{{ project.strategies|length }}</span>
                        </div>

                        <div class="pm-strategy-list pm-strategy-list-inline">
                        
                            {% for strategy in project.strategies %}
                                <section class="pm-strategy-card pm-strategy-card-inline">
                               
                                    {% if strategy.statusStrategie == strategy_statuses.approved %}
                                        <div class="pm-strategy-pdf-action" data-strategy-id="{{ strategy.idStrategie }}">
                                            <div class="pm-strategy-pdf-controls">
                                                <label class="pm-strategy-pdf-language" for="playbook_lang_{{ strategy.idStrategie }}">{{ 'project.playbook.language'|trans }}</label>
                                                <select id="playbook_lang_{{ strategy.idStrategie }}" class="pm-playbook-language-select" aria-label="{{ 'project.playbook.choose_language'|trans }}">
                                                    <option value="fr" selected>{{ 'project.playbook.french'|trans }}</option>
                                                    <option value="en">{{ 'project.playbook.english'|trans }}</option>
                                                </select>
                                            </div>
                                            <button class="pm-btn pm-btn-primary pdf-generate-btn" type="button" data-strategy-id="{{ strategy.idStrategie }}" data-generate-url="{{ path('strategy_generate_pdf', {id: strategy.idStrategie}) }}">
                                                <i class="fas fa-file-pdf"></i> {{ 'project.playbook.download'|trans }}
                                            </button>
                                            <div class="pdf-progress-container" style="display: none;">
                                                <div class="progress-circle"></div>
                                                <span class="progress-text">{{ 'project.playbook.generating'|trans }}</span>
                                            </div>
                                            <div class="pdf-download-link" style="display: none;">
                                                <a href="#" class="pm-btn pm-btn-secondary" target="_blank">
                                                    <i class="fas fa-download"></i> {{ 'project.playbook.download_simple'|trans }}
                                                </a>
                                            </div>
                                        </div>
                                    {% endif %}

                                    {% set strategy_decision_taken = strategy.statusStrategie in [strategy_statuses.approved, strategy_statuses.rejected] %}
                                    <div class="pm-strategy-main">
                                        <div>
                                            <div class="pm-strategy-topline">
                                                <h3>{{ strategy.nomStrategie }}</h3>
                                                <span class="pm-status pm-status-{{ strategy.statusCssClass }}">{{ strategy.statusLabel }}</span>
                                            </div>
                                            <p class="pm-strategy-description">
                                                {% if strategy.statusStrategie == strategy_statuses.rejected and strategy.justification %}
                                                    {{ 'project.strategy.rejection_reason'|trans }} : {{ strategy.justification }}
                                                {% elseif strategy.statusStrategie == strategy_statuses.rejected %}
                                                    {{ 'project.strategy.rejected_client'|trans }}
                                                {% elseif strategy.statusStrategie == strategy_statuses.approved %}
                                                    {{ 'project.strategy.approved_client'|trans }}
                                                {% elseif strategy.justification %}
                                                    {{ strategy.justification }}
                                                {% else %}
                                                    {{ 'project.strategy.pending_client_decision'|trans }}
                                                {% endif %}
                                            </p>
                                        </div>

                                        {% if can_client_decide_strategies and app.user and project.user and project.user.idUser == app.user.idUser %}
                                            {% if strategy_decision_taken %}
                                                <div class="pm-strategy-decision-state">
                                                    <strong>{{ 'project.strategy.confirmed'|trans }}</strong>
                                                    {{ 'project.strategy.already_saved'|trans }}
                                                </div>
                                            {% else %}
                                                <div class="pm-strategy-actions">
                                                    <form method="post" action="{{ path('project_strategy_decision', {id: strategy.idStrategie}) }}" onsubmit="return confirm('{{ 'project.strategy.confirm_accept'|trans|e('js') }}');">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('status' ~ strategy.idStrategie) }}">
                                                        <input type="hidden" name="status" value="{{ strategy_statuses.approved }}">
                                                        <button class="pm-btn pm-btn-primary" type="submit">{{ 'project.strategy.accept'|trans }}</button>
                                                    </form>

                                                    <details class="pm-strategy-reject-panel">
                                                        <summary class="pm-btn pm-btn-danger pm-strategy-reject-summary">{{ 'project.strategy.reject'|trans }}</summary>
                                                        <form method="post" action="{{ path('project_strategy_decision', {id: strategy.idStrategie}) }}" class="pm-strategy-reject-form" novalidate onsubmit="return confirm('{{ 'project.strategy.confirm_reject'|trans|e('js') }}');">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('status' ~ strategy.idStrategie) }}">
                                                            <input type="hidden" name="status" value="{{ strategy_statuses.rejected }}">
                                                            <label for="strategy_reject_{{ strategy.idStrategie }}">{{ 'project.strategy.justification_required'|trans }}</label>
                                                            <textarea id="strategy_reject_{{ strategy.idStrategie }}" name="justification" rows="4" placeholder="{{ 'project.strategy.justification_placeholder'|trans }}"></textarea>
                                                            <p class="pm-field-help">{{ 'project.strategy.justification_help'|trans }}</p>
                                                            <div class="pm-strategy-reject-actions">
                                                                <button class="pm-btn pm-btn-danger" type="submit">{{ 'project.strategy.confirm_reject_button'|trans }}</button>
                                                            </div>
                                                        </form>
                                                    </details>
                                                </div>
                                            {% endif %}
                                        {% endif %}
                                    </div>

                                    <div class="pm-strategy-meta">
                                        <span><strong>{{ 'project.strategy.type'|trans }} :</strong> {{ strategy.type ?: ('project.card.not_specified'|trans) }}</span>
                                        <span><strong>{{ 'project.strategy.duration'|trans }} :</strong> {{ strategy.DureeTerme }} {{ 'project.strategy.months'|trans }}</span>
                                        <span><strong>{{ 'project.strategy.budget'|trans }} :</strong> {{ strategy.budgetTotal is not null ? strategy.budgetTotal|number_format(2, '.', ' ') ~ ' TND' : ('project.card.not_specified'|trans) }}</span>
                                        <span><strong>{{ 'project.strategy.estimated_gain'|trans }} :</strong> {{ strategy.gainEstime is not null ? strategy.gainEstime ~ '%' : ('project.card.not_specified'|trans) }}</span>
                                        <span><strong>{{ 'project.strategy.objectives'|trans }} :</strong> {{ strategy.objectives|length }}</span>
                                    </div>
                                </section>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="pm-card-actions">
                    <a class="pm-btn pm-btn-primary" href="{{ path('project_show', {id: project.id}) }}">{{ 'project.actions.view_detail'|trans }}</a>
                    {% if app.user and project.user and project.user.idUser == app.user.idUser %}
                        <a class="pm-btn pm-btn-secondary" href="{{ path('project_manage', {id: project.id}) }}">{{ 'project.actions.manage'|trans }}</a>
                    {% elseif app.user and can_see_all_projects %}
                        <a class="pm-btn pm-btn-secondary" href="{{ path('project_back_manage', {id: project.id}) }}">{{ 'project.actions.process'|trans }}</a>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <div class="pm-empty">
                <h2>{{ 'project.empty.title'|trans }}</h2>
                <p>{{ 'project.empty.text'|trans }}</p>
            </div>
        {% endfor %}
    </section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const i18n = {
                invalidJson: {{ 'project.js.invalid_json'|trans|json_encode|raw }},
                launchError: {{ 'project.js.launch_error'|trans|json_encode|raw }},
                failed: {{ 'project.js.failed'|trans|json_encode|raw }},
                unexpected: {{ 'project.js.unexpected'|trans|json_encode|raw }},
                error: {{ 'project.js.error'|trans|json_encode|raw }},
                frLoading: {{ 'project.js.fr_loading'|trans|json_encode|raw }},
                frHtml: {{ 'project.js.fr_html'|trans|json_encode|raw }},
                frPdf: {{ 'project.js.fr_pdf'|trans|json_encode|raw }},
                enLoading: {{ 'project.js.en_loading'|trans|json_encode|raw }},
                enHtml: {{ 'project.js.en_html'|trans|json_encode|raw }},
                enPdf: {{ 'project.js.en_pdf'|trans|json_encode|raw }}
            };

            const extractServerError = (html) => {
                if (!html || typeof html !== 'string') {
                    return '';
                }

                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                const title = doc.querySelector('title')?.textContent?.trim();
                const heading = doc.querySelector('h1')?.textContent?.trim();
                const bodyText = doc.body?.textContent?.replace(/\s+/g, ' ').trim() || '';

                return title || heading || bodyText.slice(0, 220);
            };

            document.querySelectorAll('.pdf-generate-btn').forEach((button) => {
                button.addEventListener('click', async (event) => {
                    event.preventDefault();

                    const container = button.closest('.pm-strategy-pdf-action');
                    if (!container) {
                        return;
                    }

                    const progressDiv = container.querySelector('.pdf-progress-container');
                    const downloadDiv = container.querySelector('.pdf-download-link');
                    const downloadLink = downloadDiv ? downloadDiv.querySelector('a') : null;
                    const progressText = progressDiv ? progressDiv.querySelector('.progress-text') : null;
                    const languageSelect = container.querySelector('.pm-playbook-language-select');
                    const generateUrl = button.dataset.generateUrl;
                    const language = languageSelect ? languageSelect.value : 'fr';

                    const languageLabels = language === 'en'
                        ? {
                            loading: i18n.enLoading,
                            html: i18n.enHtml,
                            pdf: i18n.enPdf
                        }
                        : {
                            loading: i18n.frLoading,
                            html: i18n.frHtml,
                            pdf: i18n.frPdf
                        };

                    if (!progressDiv || !downloadDiv || !downloadLink || !generateUrl) {
                        return;
                    }

                    if (progressText) {
                        progressText.textContent = languageLabels.loading;
                    }

                    button.style.display = 'none';
                    progressDiv.style.display = 'flex';
                    downloadDiv.style.display = 'none';

                    const showDownload = (url, label) => {
                        progressDiv.style.display = 'none';
                        downloadDiv.style.display = 'block';
                        downloadLink.href = url;
                        downloadLink.innerHTML = `<i class="fas fa-download"></i> ${label}`;
                    };

                    const resetState = () => {
                        progressDiv.style.display = 'none';
                        button.style.display = 'inline-flex';
                    };

                    try {
                        const response = await fetch(generateUrl, {
                            method: 'POST',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Accept': 'application/json',
                                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                            },
                            body: new URLSearchParams({
                                lang: language
                            }).toString()
                        });

                        const responseText = await response.text();
                        let data = null;

                        if (responseText.trim() !== '') {
                            try {
                                data = JSON.parse(responseText);
                            } catch (parseError) {
                                throw new Error(
                                    extractServerError(responseText)
                                    || `${i18n.invalidJson} (${response.status}).`
                                );
                            }
                        }

                        if (!response.ok) {
                            throw new Error(data?.error || `${i18n.launchError} (${response.status}).`);
                        }

                        if (data?.status === 'failed') {
                            throw new Error(data.error || i18n.failed);
                        }

                        if (data?.status === 'completed' && data.url) {
                            const isHtmlFallback = data.format === 'html';
                            showDownload(data.url, isHtmlFallback ? languageLabels.html : languageLabels.pdf);

                            if (data.message) {
                                alert(data.message);
                            }

                            return;
                        }

                        throw new Error(i18n.unexpected);
                    } catch (error) {
                        resetState();
                        alert(i18n.error + ': ' + error.message);
                    }
                });
            });
        });
    </script>
{% endblock %}
