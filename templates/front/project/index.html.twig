{% extends 'base.html.twig' %}

{% block title %}Advisora | Projets{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% block body %}
    <section class="pm-hero">
        <div>
            <span class="pm-badge">Project Management</span>
            <h1>Suivez les projets strategiques d'Advisora</h1>
            <p>
                {% if app.user and not can_see_all_projects %}
                    Consultez uniquement vos projets et les decisions prises sur vos initiatives.
                {% else %}
                    Consultez l'etat des projets et les decisions prises pour chaque initiative.
                {% endif %}
            </p>
        </div>
        <div class="pm-actions">
            {% if app.user and can_manage_projects %}
                <a class="pm-btn pm-btn-primary" href="{{ path('project_new') }}">Ajouter un projet</a>
            {% elseif not app.user %}
                <a class="pm-btn pm-btn-primary" href="{{ path('app_login') }}">Se connecter pour gerer</a>
            {% endif %}
        </div>
    </section>

    <section class="pm-hero">
        <form method="get" action="{{ path('project_index') }}" class="pm-form-card">
            <div class="pm-filter-grid">
                <div class="pm-field">
                    <label for="filter_q">Recherche</label>
                    <input id="filter_q" type="search" name="q" placeholder="Titre, description, type, statut ou ID..." value="{{ filters.q|default('') }}">
                </div>

                <div class="pm-field">
                    <label for="filter_status">Statut</label>
                    <select id="filter_status" name="status">
                        <option value="">Tous</option>
                        {% for status_value, status_label in status_choices %}
                            <option value="{{ status_value }}" {% if filters.status is defined and filters.status == status_value %}selected{% endif %}>{{ status_label }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="pm-field">
                    <label for="filter_type">Type</label>
                    <select id="filter_type" name="type">
                        <option value="">Tous</option>
                        {% for project_type in type_choices %}
                            <option value="{{ project_type }}" {% if filters.type is defined and filters.type == project_type %}selected{% endif %}>{{ project_type }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div class="pm-field">
                    <label for="filter_min_price">Budget min</label>
                    <input id="filter_min_price" type="number" step="0.01" name="min_price" placeholder="Min" value="{{ filters.min_price|default('') }}">
                </div>

                <div class="pm-field">
                    <label for="filter_max_price">Budget max</label>
                    <input id="filter_max_price" type="number" step="0.01" name="max_price" placeholder="Max" value="{{ filters.max_price|default('') }}">
                </div>
            </div>

            <div class="pm-filter-actions">
                <button class="pm-btn pm-btn-primary" type="submit">Filtrer</button>
                <a class="pm-btn pm-btn-secondary" href="{{ path('project_index') }}">Reinitialiser</a>
            </div>
        </form>
    </section>

    <section class="pm-grid">
        {% for project in projects %}
            <article class="pm-card">
                <div class="pm-card-head">
                    <span class="pm-status pm-status-{{ project.status|lower }}">{{ project.getStatusLabel() }}</span>
                    <span class="pm-meta">Projet #{{ project.id }}</span>
                </div>
                <h2>{{ project.title }}</h2>
                <p>{{ project.description ?: 'Aucune description pour ce projet.' }}</p>
                <div class="pm-meta-list">
                    <span><i class="fas fa-layer-group"></i> Type : {{ project.legacyType ?: 'Non precise' }}</span>
                    <span><i class="fas fa-wallet"></i> Budget : {{ project.legacyBudget is not null ? project.legacyBudget|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</span>
                    <span><i class="fas fa-calendar-plus"></i> Creation : {{ project.startDate ? project.startDate|date('d/m/Y') : 'Non precisee' }}</span>
                </div>
                <div class="pm-meta-list">
                    <span><i class="fas fa-sitemap"></i> {{ project.decisions|length }} decision(s)</span>
                </div>

                {% if project.strategies|length > 0 %}
                    <div class="pm-project-strategies pm-project-strategies-inline">
                        <div class="pm-section-head">
                            <div>
                                <span class="pm-badge">Strategies proposees</span>
                                <p class="pm-section-text">Consultez les strategies rattachees a ce projet et, pour le client proprietaire, choisissez de les accepter ou de les refuser.</p>
                            </div>
                            <span class="pm-history-count">{{ project.strategies|length }}</span>
                        </div>

                        <div class="pm-strategy-list pm-strategy-list-inline">
                            {% for strategy in project.strategies %}
                                <section class="pm-strategy-card pm-strategy-card-inline">
                                    <div class="pm-strategy-main">
                                        <div>
                                            <div class="pm-strategy-topline">
                                                <h3>{{ strategy.nomStrategie }}</h3>
                                                <span class="pm-status pm-status-{{ strategy.statusCssClass }}">{{ strategy.statusLabel }}</span>
                                            </div>
                                            <p class="pm-strategy-description">{{ strategy.justification ?: 'Aucune justification fournie.' }}</p>
                                        </div>

                                        {% if can_client_decide_strategies and app.user and project.user and project.user.idUser == app.user.idUser %}
                                            <div class="pm-strategy-actions">
                                                <form method="post" action="{{ path('project_strategy_decision', {id: strategy.idStrategie}) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('status' ~ strategy.idStrategie) }}">
                                                    <input type="hidden" name="status" value="{{ strategy_statuses.approved }}">
                                                    <button class="pm-btn pm-btn-primary" type="submit" {% if strategy.statusStrategie == strategy_statuses.approved %}disabled{% endif %}>Accepter</button>
                                                </form>

                                                <form method="post" action="{{ path('project_strategy_decision', {id: strategy.idStrategie}) }}">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('status' ~ strategy.idStrategie) }}">
                                                    <input type="hidden" name="status" value="{{ strategy_statuses.rejected }}">
                                                    <button class="pm-btn pm-btn-danger" type="submit" {% if strategy.statusStrategie == strategy_statuses.rejected %}disabled{% endif %}>Refuser</button>
                                                </form>
                                            </div>
                                        {% endif %}
                                    </div>

                                    <div class="pm-strategy-meta">
                                        <span><strong>Type :</strong> {{ strategy.type ?: 'Non precise' }}</span>
                                        <span><strong>Duree :</strong> {{ strategy.DureeTerme }} mois</span>
                                        <span><strong>Budget :</strong> {{ strategy.budgetTotal is not null ? strategy.budgetTotal|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</span>
                                        <span><strong>Gain estime :</strong> {{ strategy.gainEstime is not null ? strategy.gainEstime ~ '%' : 'Non precise' }}</span>
                                        <span><strong>Objectifs :</strong> {{ strategy.objectives|length }}</span>
                                    </div>
                                </section>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                <div class="pm-card-actions">
                    <a class="pm-btn pm-btn-primary" href="{{ path('project_show', {id: project.id}) }}">Voir le detail</a>
                    {% if app.user and project.user and project.user.idUser == app.user.idUser %}
                        <a class="pm-btn pm-btn-secondary" href="{{ path('project_manage', {id: project.id}) }}">Gerer</a>
                    {% elseif app.user and can_see_all_projects %}
                        <a class="pm-btn pm-btn-secondary" href="{{ path('project_back_manage', {id: project.id}) }}">Traiter</a>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <div class="pm-empty">
                <h2>Aucun projet pour le moment</h2>
                <p>Commencez par creer un premier projet strategique depuis l espace projets.</p>
            </div>
        {% endfor %}
    </section>
{% endblock %}
