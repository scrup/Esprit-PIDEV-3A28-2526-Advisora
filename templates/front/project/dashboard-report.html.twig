<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport projets Advisora</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            color: #2c2418;
            margin: 28px;
            line-height: 1.45;
        }

        h1, h2, h3 {
            margin: 0;
        }

        .report-top {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            margin-bottom: 24px;
            align-items: flex-start;
        }

        .report-top h1 {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .report-kicker {
            display: inline-block;
            background: #ead8ca;
            color: #8d563d;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 10px;
        }

        .report-meta {
            font-size: 13px;
            color: #6b5a48;
        }

        .report-notice {
            margin: 0 0 18px;
            padding: 12px 16px;
            border-radius: 12px;
            background: #fff6ef;
            color: #8d563d;
            border: 1px solid #ead8ca;
        }

        .report-filters {
            margin: 10px 0 0;
            padding: 0;
            list-style: none;
        }

        .report-filters li {
            margin-bottom: 4px;
            color: #6b5a48;
        }

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin: 18px 0 24px;
        }

        .summary-card,
        .chart-card,
        .table-card {
            border: 1px solid #ead8ca;
            border-radius: 16px;
            padding: 16px;
            background: #fffdfa;
        }

        .summary-card span,
        .chart-card span {
            display: block;
            color: #6b5a48;
            font-size: 12px;
            margin-bottom: 8px;
        }

        .summary-card strong {
            display: block;
            font-size: 24px;
            margin-bottom: 6px;
            color: #8d563d;
        }

        .chart-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
            margin-bottom: 24px;
        }

        .chart-card h3 {
            margin-bottom: 14px;
            font-size: 18px;
        }

        .bar-list {
            display: grid;
            gap: 12px;
        }

        .bar-row {
            display: grid;
            gap: 6px;
        }

        .bar-meta {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            font-size: 13px;
        }

        .bar-track {
            height: 10px;
            border-radius: 999px;
            background: #f1e7db;
            overflow: hidden;
        }

        .bar-fill {
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(135deg, #c37d5d, #8d563d);
        }

        .table-card h2 {
            margin-bottom: 14px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
        }

        th, td {
            padding: 10px 8px;
            text-align: left;
            border-bottom: 1px solid #f1e7db;
        }

        th {
            color: #6b5a48;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .status-pill {
            display: inline-block;
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 11px;
            font-weight: bold;
            background: #ead8ca;
            color: #8d563d;
        }
    </style>
</head>
<body>
    <header class="report-top">
        <div>
            <span class="report-kicker">{{ dashboard.export_meta.role_label }}</span>
            <h1>Rapport projet Advisora</h1>
            <p>Tableau de bord synthese et liste des projets visibles dans le scope actuel.</p>
        </div>
        <div class="report-meta">
            <div><strong>Date :</strong> {{ dashboard.export_meta.generated_at|date('d/m/Y H:i') }}</div>
            <div><strong>Volume :</strong> {{ dashboard.summary.total_projects }} projet(s)</div>
            <div><strong>Taux d acceptation :</strong> {{ dashboard.summary.acceptance_rate|number_format(1, '.', ' ') }}%</div>
        </div>
    </header>

    {% if export_notice %}
        <div class="report-notice">{{ export_notice }}</div>
    {% endif %}

    {% if dashboard.export_meta.filters is not empty %}
        <ul class="report-filters">
            {% for filter in dashboard.export_meta.filters %}
                <li><strong>{{ filter.label }} :</strong> {{ filter.value }}</li>
            {% endfor %}
        </ul>
    {% endif %}

    <section class="summary-grid">
        <article class="summary-card">
            <span>Projets visibles</span>
            <strong>{{ dashboard.summary.total_projects }}</strong>
            <div>{{ dashboard.summary.active_types }} type(s) actif(s)</div>
        </article>
        <article class="summary-card">
            <span>En attente</span>
            <strong>{{ dashboard.summary.pending_projects }}</strong>
            <div>{{ dashboard.summary.accepted_projects }} acceptes</div>
        </article>
        <article class="summary-card">
            <span>Budget total</span>
            <strong>{{ dashboard.summary.total_budget|number_format(2, '.', ' ') }} TND</strong>
            <div>Moyenne : {{ dashboard.summary.average_budget|number_format(2, '.', ' ') }} TND</div>
        </article>
        <article class="summary-card">
            <span>Refuses</span>
            <strong>{{ dashboard.summary.refused_projects }}</strong>
            <div>Statuts consolides</div>
        </article>
    </section>

    {% set chart_groups = [
        {'title': 'Repartition par statut', 'chart': dashboard.charts.status, 'suffix': ''},
        {'title': 'Typologies dominantes', 'chart': dashboard.charts.types, 'suffix': ''},
        {'title': 'Evolution mensuelle', 'chart': dashboard.charts.timeline, 'suffix': ''},
        {'title': 'Budget moyen par statut', 'chart': dashboard.charts.budgets, 'suffix': ' TND'}
    ] %}

    <section class="chart-grid">
        {% for group in chart_groups %}
            {% set max_value = 0 %}
            {% for value in group.chart.values %}
                {% set max_value = value > max_value ? value : max_value %}
            {% endfor %}
            <article class="chart-card">
                <h3>{{ group.title }}</h3>
                {% if group.chart.labels is not empty %}
                    <div class="bar-list">
                        {% for label in group.chart.labels %}
                            {% set value = group.chart.values[loop.index0]|default(0) %}
                            {% set width = max_value > 0 ? (value / max_value) * 100 : 0 %}
                            <div class="bar-row">
                                <div class="bar-meta">
                                    <strong>{{ label }}</strong>
                                    <span>{{ value|number_format(0, '.', ' ') }}{{ group.suffix }}</span>
                                </div>
                                <div class="bar-track">
                                    <div class="bar-fill" style="width: {{ width }}%"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p>Aucune donnee disponible.</p>
                {% endif %}
            </article>
        {% endfor %}
    </section>

    <section class="table-card">
        <h2>Liste des projets visibles</h2>
        {% if dashboard.projects is not empty %}
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Statut</th>
                        <th>Budget</th>
                        <th>Porteur</th>
                        <th>Creation</th>
                    </tr>
                </thead>
                <tbody>
                    {% for project in dashboard.projects %}
                        <tr>
                            <td>#{{ project.id }}</td>
                            <td>{{ project.title ?: 'Projet sans titre' }}</td>
                            <td>{{ project.legacyType ?: 'Non precise' }}</td>
                            <td><span class="status-pill">{{ project.statusLabel }}</span></td>
                            <td>{{ project.legacyBudget is not null ? project.legacyBudget|number_format(2, '.', ' ') ~ ' TND' : 'Non precise' }}</td>
                            <td>{{ project.user ? project.user.getPrenomUser() ~ ' ' ~ project.user.getNomUser() : 'Non assigne' }}</td>
                            <td>{{ project.startDate ? project.startDate|date('d/m/Y') : 'Non precisee' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p>Aucun projet a exporter dans ce scope.</p>
        {% endif %}
    </section>
</body>
</html>
