{% extends 'base.html.twig' %}

{% block title %}Advisora | {{ page_title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/project-management.css') }}">
{% endblock %}

{% macro field(field) %}
    <div class="pm-field {% if field.vars.errors|length > 0 %}pm-field-has-error{% endif %}">
        {{ form_label(field) }}
        {{ form_widget(field) }}
        {% if field.vars.help %}
            <div class="pm-field-help">{{ form_help(field) }}</div>
        {% endif %}
        <div class="pm-field-errors" data-field-errors>
            {{ form_errors(field) }}
        </div>
    </div>
{% endmacro %}

{% block body %}
    {% import _self as forms %}
    <section class="pm-admin-shell">
        <div class="pm-admin-header">
            <div>
                <span class="pm-badge">Inscription client</span>
                <h1>{{ page_title }}</h1>
                <p>Vous reservez des tickets sur la table `bookings` existante, sans modifier le schema MySQL.</p>
            </div>
            <a class="pm-btn pm-btn-secondary" href="{{ back_route == 'event_show' ? path(back_route, {id: event.id}) : path(back_route) }}">Retour</a>
        </div>

        <div class="pm-form-card">
            <div class="pm-info-banner">
                <strong>Evenement :</strong> {{ event.title }}<br>
                <strong>Organisateur :</strong> {{ event.organizerName ?: 'Non renseigne' }}<br>
                <strong>Lieu :</strong> {{ event.location ?: 'Non renseigne' }}<br>
                <strong>Places restantes :</strong> {{ event.remainingTickets }}
                {% if booking.id %}
                    <br><strong>Statut :</strong> <span class="pm-status pm-status-{{ booking.workflowStatusCssClass }}">{{ booking.workflowStatusLabel }}</span>
                {% endif %}
            </div>
            {{ form_start(form, {attr: {novalidate: 'novalidate', class: 'pm-validated-form'}}) }}
                {{ form_errors(form) }}
                <div class="pm-form-grid">
                    {{ forms.field(form.numTicketBk) }}
                </div>
                <div class="pm-form-actions">
                    {{ form_row(form.save) }}
                </div>
            {{ form_end(form) }}
        </div>
    </section>
{% endblock %}
