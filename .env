###> app/shop-image-generator ###
POLLINATIONS_API_KEY=
SHOP_IMAGE_GENERATOR_MODEL=zimage
SHOP_IMAGE_GENERATOR_SIZE=1536x1024
###< app/shop-image-generator ###

###> app/gemini-pdf ###
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOTENBERG_URL=http://127.0.0.1:3000
###< app/gemini-pdf ###

###> app/google-oauth ###
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
# Route name or full URL used for the Google OAuth redirect URI.
# Example: https://127.0.0.1:8000/connect/google/check
OAUTH_GOOGLE_REDIRECT_URI=connect_google_check
###< app/google-oauth ###

###> app/turnstile ###
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
###< app/turnstile ###

###> app/captcha ###
# CAPTCHA_PROVIDER: turnstile | image | math | none
# If empty, defaults to "turnstile" when keys are set, otherwise "image".
CAPTCHA_PROVIDER=
###< app/captcha ###

